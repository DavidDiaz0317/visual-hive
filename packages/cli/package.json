{
  "name": "@visual-hive/cli",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "visual-hive": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@visual-hive/core": "*",
    "@visual-hive/github-adapter": "*",
    "@visual-hive/llm-adapter": "*",
    "@visual-hive/playwright-adapter": "*",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
