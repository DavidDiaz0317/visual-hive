{
  "name": "@visual-hive/cli",
  "version": "0.4.1",
  "description": "Visual Hive command-line interface.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DavidDiaz0317/visual-hive.git",
    "directory": "packages/cli"
  },
  "engines": {
    "node": ">=22"
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "bin": {
    "visual-hive": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node ../../scripts/copy-cli-schemas.mjs",
    "prepack": "node ../../scripts/build-cli-release-package.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@visual-hive/control-plane": "*",
    "@visual-hive/core": "*",
    "@visual-hive/github-adapter": "*",
    "@visual-hive/llm-adapter": "*",
    "@visual-hive/playwright-adapter": "*",
    "commander": "^12.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.10"
  }
}
