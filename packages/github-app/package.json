{
  "name": "@visual-hive/github-app",
  "version": "0.4.1",
  "description": "GitHub App local/server MVP helpers for Visual Hive trusted issue-centric repository connections.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DavidDiaz0317/visual-hive.git",
    "directory": "packages/github-app"
  },
  "engines": {
    "node": ">=22"
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "npm run build && node dist/server.js",
    "start": "node dist/server.js",
    "smoke:mock": "node dist/mock.js --event workflow_run --output-dir .visual-hive",
    "smoke:live": "node dist/liveSmoke.js --output-dir .visual-hive",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run packages/github-app/tests/githubApp.test.ts --root ../.."
  },
  "dependencies": {
    "@visual-hive/core": "*"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.10"
  }
}
