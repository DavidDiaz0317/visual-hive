{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://visual-hive.dev/schemas/visual-hive.release.schema.json",
  "title": "Visual Hive Release Bundle Manifest",
  "type": "object",
  "required": [
    "schemaVersion",
    "name",
    "version",
    "gitCommit",
    "node",
    "entrypoint",
    "playwrightVersion",
    "files"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": "visual-hive.release.v1" },
    "name": { "const": "visual-hive" },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:[-+][A-Za-z0-9.-]+)?$" },
    "gitCommit": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
    "node": { "const": ">=22" },
    "entrypoint": { "const": "visual-hive.mjs" },
    "playwrightVersion": { "type": "string", "minLength": 1 },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "sha256", "size"],
        "additionalProperties": false,
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1,
            "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\).+$"
          },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "size": { "type": "integer", "minimum": 0 }
        }
      }
    }
  }
}
