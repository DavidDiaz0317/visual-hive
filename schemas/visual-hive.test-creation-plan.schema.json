{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://visual-hive.dev/schemas/visual-hive.test-creation-plan.schema.json",
  "title": "Visual Hive Test Creation Plan",
  "type": "object",
  "required": [
    "schemaVersion",
    "generatedAt",
    "project",
    "sourceArtifacts",
    "governance",
    "summary",
    "recommendations"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "visual-hive.test-creation-plan.v1"
    },
    "generatedAt": {
      "type": "string"
    },
    "project": {
      "type": "string"
    },
    "outputResource": {
      "$ref": "#/$defs/outputResource"
    },
    "sourceArtifacts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "evidencePacket": {
          "type": "string"
        },
        "coverageRecommendations": {
          "type": "string"
        },
        "handoffPacket": {
          "type": "string"
        }
      }
    },
    "governance": {
      "type": "object",
      "required": [
        "verdictAuthority",
        "agentAuthority",
        "writePolicy",
        "secretPolicy"
      ],
      "additionalProperties": false,
      "properties": {
        "verdictAuthority": {
          "const": "visual_hive"
        },
        "agentAuthority": {
          "const": "advisory_test_generation_only"
        },
        "writePolicy": {
          "const": "no_config_or_test_files_written"
        },
        "secretPolicy": {
          "const": "redacted_values_names_only"
        }
      }
    },
    "summary": {
      "type": "object",
      "required": [
        "total",
        "high",
        "medium",
        "low",
        "fromTestingLayers",
        "fromCoverageRecommendations",
        "fromMutationSurvivors",
        "fromHandoffWorkItems"
      ],
      "additionalProperties": false,
      "properties": {
        "total": {
          "type": "number"
        },
        "high": {
          "type": "number"
        },
        "medium": {
          "type": "number"
        },
        "low": {
          "type": "number"
        },
        "fromTestingLayers": {
          "type": "number"
        },
        "fromCoverageRecommendations": {
          "type": "number"
        },
        "fromMutationSurvivors": {
          "type": "number"
        },
        "fromHandoffWorkItems": {
          "type": "number"
        }
      }
    },
    "recommendations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/recommendation"
      }
    }
  },
  "$defs": {
    "outputResource": {
      "type": "object",
      "required": [
        "artifactPath",
        "evidenceResourceId",
        "evidenceResourceUri",
        "evidenceResourceTitle",
        "evidenceResourceDescription"
      ],
      "additionalProperties": false,
      "properties": {
        "artifactPath": {
          "const": ".visual-hive/test-creation-plan.json"
        },
        "evidenceResourceId": {
          "const": "test-creation-plan"
        },
        "evidenceResourceUri": {
          "const": "visual-hive://test-creation-plan"
        },
        "evidenceResourceTitle": {
          "const": "Test Creation Plan"
        },
        "evidenceResourceDescription": {
          "type": "string"
        },
        "evidenceReadToolName": {
          "const": "visual_hive_read_test_creation_plan"
        }
      }
    },
    "recommendation": {
      "type": "object",
      "required": [
        "id",
        "gapId",
        "source",
        "kind",
        "priority",
        "title",
        "rationale",
        "affected",
        "currentEvidence",
        "suggestedContract",
        "suggestedMutation",
        "validationCommand",
        "hiveOwner",
        "suggestedTests",
        "artifacts",
        "trustedOnly",
        "applyMode"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "gapId": {
          "type": "string"
        },
        "source": {
          "enum": [
            "testing_layer",
            "coverage_recommendation",
            "mutation_survivor",
            "handoff_work_item"
          ]
        },
        "kind": {
          "enum": [
            "unit_test",
            "accessibility_check",
            "api_contract",
            "selector_assertion",
            "screenshot",
            "flow",
            "mutation_mapping",
            "workflow_setup",
            "provider_review",
            "protected_canary",
            "history_review",
            "agent_handoff"
          ]
        },
        "priority": {
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "title": {
          "type": "string"
        },
        "rationale": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "affected": {
          "$ref": "#/$defs/affected"
        },
        "currentEvidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "suggestedContract": {
          "$ref": "#/$defs/suggestedContract"
        },
        "suggestedMutation": {
          "type": "string"
        },
        "validationCommand": {
          "type": "string"
        },
        "hiveOwner": {
          "enum": [
            "quality",
            "tester",
            "ci-maintainer"
          ]
        },
        "layer": {
          "type": "object",
          "required": [
            "id",
            "name",
            "status"
          ],
          "additionalProperties": false,
          "properties": {
            "id": {
              "type": "number"
            },
            "name": {
              "type": "string"
            },
            "status": {
              "enum": [
                "covered",
                "partial",
                "missing",
                "not_applicable",
                "unknown"
              ]
            }
          }
        },
        "targetId": {
          "type": "string"
        },
        "contractId": {
          "type": "string"
        },
        "mutationOperator": {
          "type": "string"
        },
        "coverageRecommendationId": {
          "type": "string"
        },
        "handoffWorkItemId": {
          "type": "string"
        },
        "suggestedTests": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "suggestedConfigYaml": {
          "type": "string"
        },
        "artifacts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "trustedOnly": {
          "type": "boolean"
        },
        "applyMode": {
          "const": "advisory_no_write"
        }
      }
    },
    "affected": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "route": {
          "type": "string"
        },
        "component": {
          "type": "string"
        },
        "viewport": {
          "type": "string"
        },
        "state": {
          "type": "string"
        }
      }
    },
    "suggestedContract": {
      "type": "object",
      "required": [
        "id",
        "description",
        "route",
        "selectors"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "targetId": {
          "type": "string"
        },
        "route": {
          "type": "string"
        },
        "viewport": {
          "type": "string"
        },
        "selectors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
