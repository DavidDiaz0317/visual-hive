{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://visual-hive.local/schemas/visual-hive.provider-results.schema.json",
  "title": "Visual Hive Provider Adapter Mock Results",
  "type": "object",
  "required": [
    "schemaVersion",
    "project",
    "generatedAt",
    "deterministicStatus",
    "artifactCount",
    "providers",
    "summary",
    "warnings"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "project": { "type": "string" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "deterministicStatus": { "enum": ["passed", "failed"] },
    "artifactCount": { "type": "integer", "minimum": 0 },
    "providers": {
      "type": "array",
      "items": { "$ref": "#/$defs/provider" }
    },
    "summary": {
      "type": "object",
      "required": [
        "providerCount",
        "enabledProviders",
        "mockProviders",
        "missingCredentialProviders",
        "externalDeferredProviders",
        "skippedProviders",
        "failedProviders"
      ],
      "properties": {
        "providerCount": { "type": "integer", "minimum": 0 },
        "enabledProviders": { "type": "integer", "minimum": 0 },
        "mockProviders": { "type": "integer", "minimum": 0 },
        "missingCredentialProviders": { "type": "integer", "minimum": 0 },
        "externalDeferredProviders": { "type": "integer", "minimum": 0 },
        "skippedProviders": { "type": "integer", "minimum": 0 },
        "failedProviders": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "provider": {
      "type": "object",
      "required": [
        "providerId",
        "label",
        "enabled",
        "mode",
        "availability",
        "deterministicRole",
        "operations",
        "result",
        "normalized",
        "artifacts",
        "missingEnv",
        "warnings"
      ],
      "properties": {
        "providerId": { "type": "string" },
        "label": { "type": "string" },
        "enabled": { "type": "boolean" },
        "mode": { "enum": ["mock", "external"] },
        "availability": { "enum": ["available", "disabled", "missing_credentials", "mock"] },
        "deterministicRole": { "enum": ["oracle", "supplemental"] },
        "operations": {
          "type": "array",
          "items": { "$ref": "#/$defs/operation" }
        },
        "result": { "$ref": "#/$defs/result" },
        "normalized": { "$ref": "#/$defs/normalized" },
        "artifacts": {
          "type": "array",
          "items": { "type": "string" }
        },
        "missingEnv": {
          "type": "array",
          "items": { "type": "string" }
        },
        "warnings": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "operation": {
      "type": "object",
      "required": ["operation", "status", "message"],
      "properties": {
        "operation": {
          "enum": ["availability", "upload_artifact", "compare", "fetch_result", "normalize_result", "emit_report_metadata"]
        },
        "status": { "enum": ["passed", "failed", "skipped", "mock"] },
        "message": { "type": "string" },
        "artifactCount": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "result": {
      "type": "object",
      "required": [
        "providerId",
        "label",
        "status",
        "deterministicRole",
        "message",
        "requiredEnv",
        "missingEnv",
        "artifactCount",
        "normalizedAt"
      ],
      "properties": {
        "providerId": { "type": "string" },
        "label": { "type": "string" },
        "status": { "enum": ["passed", "failed", "skipped", "missing_credentials", "mock"] },
        "deterministicRole": { "enum": ["oracle", "supplemental"] },
        "message": { "type": "string" },
        "requiredEnv": {
          "type": "array",
          "items": { "type": "string" }
        },
        "missingEnv": {
          "type": "array",
          "items": { "type": "string" }
        },
        "artifactCount": { "type": "integer", "minimum": 0 },
        "externalUrl": { "type": "string" },
        "normalizedAt": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    },
    "normalized": {
      "type": "object",
      "required": [
        "providerId",
        "category",
        "status",
        "deterministicRole",
        "networkMode",
        "externalCallsMade",
        "artifactSummary",
        "notes"
      ],
      "properties": {
        "providerId": { "type": "string" },
        "category": { "enum": ["built-in", "hosted-visual", "component", "ci"] },
        "status": { "enum": ["passed", "failed", "skipped", "missing_credentials", "mock"] },
        "deterministicRole": { "enum": ["oracle", "supplemental"] },
        "networkMode": { "enum": ["local", "mock", "deferred", "disabled", "missing_credentials"] },
        "externalCallsMade": { "const": 0 },
        "artifactSummary": {
          "type": "object",
          "required": ["localArtifacts", "uploadedArtifacts", "comparedArtifacts", "uploadMode"],
          "properties": {
            "localArtifacts": { "type": "integer", "minimum": 0 },
            "uploadedArtifacts": { "type": "integer", "minimum": 0 },
            "comparedArtifacts": { "type": "integer", "minimum": 0 },
            "uploadMode": { "enum": ["local-only", "mock", "deferred", "not-supported", "disabled", "blocked"] }
          },
          "additionalProperties": false
        },
        "hostedVisual": {
          "type": "object",
          "required": ["provider", "baselinePolicy"],
          "properties": {
            "provider": { "enum": ["argos", "percy", "chromatic", "applitools"] },
            "projectId": { "type": "string" },
            "reviewUrl": { "type": "string" },
            "baselinePolicy": { "enum": ["visual-hive-owned", "provider-owned-future"] }
          },
          "additionalProperties": false
        },
        "storybook": {
          "type": "object",
          "required": ["mode", "recommendedCommand", "coverageHint"],
          "properties": {
            "mode": { "enum": ["mock", "deferred", "disabled"] },
            "recommendedCommand": { "type": "string" },
            "coverageHint": { "type": "string" }
          },
          "additionalProperties": false
        },
        "githubChecks": {
          "type": "object",
          "required": ["checkName", "conclusion", "annotationCount", "trustedIssueWorkflowRequired"],
          "properties": {
            "checkName": { "type": "string" },
            "conclusion": { "enum": ["success", "failure", "neutral", "skipped"] },
            "annotationCount": { "type": "integer", "minimum": 0 },
            "trustedIssueWorkflowRequired": { "const": true }
          },
          "additionalProperties": false
        },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    }
  }
}
