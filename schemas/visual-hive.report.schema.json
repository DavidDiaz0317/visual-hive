{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://visual-hive.dev/schemas/visual-hive.report.schema.json",
  "title": "Visual Hive Report",
  "type": "object",
  "required": ["schemaVersion", "project", "mode", "generatedAt", "status", "changedFiles", "results", "consoleErrors"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": 1 },
    "project": { "type": "string" },
    "mode": { "enum": ["pr", "schedule", "manual"] },
    "generatedAt": { "type": "string" },
    "status": { "enum": ["passed", "failed"] },
    "changedFiles": { "type": "array", "items": { "type": "string" } },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["contractId", "targetId", "status", "durationMs", "errors", "artifacts"],
        "additionalProperties": false,
        "properties": {
          "contractId": { "type": "string" },
          "targetId": { "type": "string" },
          "status": { "enum": ["passed", "failed", "created", "skipped"] },
          "durationMs": { "type": "number", "minimum": 0 },
          "errors": { "type": "array", "items": { "type": "string" } },
          "artifacts": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "consoleErrors": { "type": "array", "items": { "type": "string" } }
  }
}
