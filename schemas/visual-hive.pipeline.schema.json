{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://visual-hive.dev/schemas/visual-hive.pipeline.schema.json",
  "title": "Visual Hive Pipeline Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "project",
    "mode",
    "generatedAt",
    "status",
    "exitCode",
    "options",
    "steps",
    "artifacts"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "project": {
      "type": "string"
    },
    "mode": {
      "enum": [
        "pr",
        "schedule",
        "manual",
        "canary",
        "mutation",
        "full"
      ]
    },
    "generatedAt": {
      "type": "string"
    },
    "status": {
      "enum": [
        "passed",
        "failed",
        "blocked"
      ]
    },
    "exitCode": {
      "type": "integer"
    },
    "rootCause": {
      "type": "string"
    },
    "options": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ci",
        "bootstrapBaselines",
        "enforceMutation",
        "continueOnError",
        "skipInstall",
        "skipBuild"
      ],
      "properties": {
        "ci": {
          "type": "boolean"
        },
        "bootstrapBaselines": {
          "type": "boolean"
        },
        "enforceMutation": {
          "type": "boolean"
        },
        "continueOnError": {
          "type": "boolean"
        },
        "skipInstall": {
          "type": "boolean"
        },
        "skipBuild": {
          "type": "boolean"
        },
        "changedFiles": {
          "type": "string"
        },
        "base": {
          "type": "string"
        }
      }
    },
    "steps": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/step"
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "status",
        "startedAt",
        "completedAt",
        "durationMs",
        "exitCode",
        "artifacts"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "status": {
          "enum": [
            "passed",
            "failed",
            "skipped"
          ]
        },
        "startedAt": {
          "type": "string"
        },
        "completedAt": {
          "type": "string"
        },
        "durationMs": {
          "type": "number",
          "minimum": 0
        },
        "exitCode": {
          "type": "integer"
        },
        "artifacts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "message": {
          "type": "string"
        }
      }
    }
  }
}
