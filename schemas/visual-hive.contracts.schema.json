{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://visual-hive.dev/schemas/visual-hive.contracts.schema.json",
  "title": "Visual Hive Contract Audit",
  "type": "object",
  "additionalProperties": true,
  "required": ["schemaVersion", "project", "generatedAt", "summary", "contracts"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "project": { "type": "string" },
    "generatedAt": { "type": "string" },
    "mode": { "enum": ["pr", "schedule", "manual", "canary", "mutation", "full"] },
    "summary": {
      "type": "object",
      "required": [
        "contractCount",
        "selectedContracts",
        "notRunContracts",
        "failedContracts",
        "assertionFreeContracts",
        "screenshotlessContracts",
        "contractsWithoutWaitFor",
        "contractsWithoutChangedFileRules",
        "mutationMappedContracts",
        "contractsWithHighSeverityGaps"
      ],
      "properties": {
        "contractCount": { "type": "number" },
        "selectedContracts": { "type": "number" },
        "notRunContracts": { "type": "number" },
        "failedContracts": { "type": "number" },
        "assertionFreeContracts": { "type": "number" },
        "screenshotlessContracts": { "type": "number" },
        "contractsWithoutWaitFor": { "type": "number" },
        "contractsWithoutChangedFileRules": { "type": "number" },
        "mutationMappedContracts": { "type": "number" },
        "contractsWithHighSeverityGaps": { "type": "number" }
      }
    },
    "contracts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "description",
          "targetId",
          "targetKind",
          "targetPrSafe",
          "targetCost",
          "severity",
          "runOn",
          "waitFor",
          "selectors",
          "flowStepCount",
          "screenshots",
          "routes",
          "viewports",
          "consoleRules",
          "selected",
          "latestStatus",
          "mutationMappings",
          "mutationResults",
          "changedFileRules",
          "gaps",
          "recommendations"
        ],
        "properties": {
          "flowStepCount": { "type": "number" },
          "latestStatus": { "enum": ["passed", "failed", "created", "skipped", "not_run"] },
          "gaps": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["kind", "severity", "message"],
              "properties": {
                "kind": {
                  "enum": [
                    "no_assertions",
                    "no_screenshots",
                    "no_wait_for",
                    "no_changed_file_rule",
                    "pr_unsafe_target",
                    "not_selected",
                    "failed_latest_run",
                    "no_mutation_mapping"
                  ]
                },
                "severity": { "enum": ["low", "medium", "high"] },
                "message": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
