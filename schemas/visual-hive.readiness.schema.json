{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://visual-hive.dev/schemas/visual-hive.readiness.schema.json",
  "title": "Visual Hive Readiness Gate",
  "type": "object",
  "required": ["schemaVersion", "project", "generatedAt", "status", "score", "summary", "inputs", "gates", "nextActions"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "project": { "type": "string" },
    "generatedAt": { "type": "string" },
    "status": { "enum": ["ready", "attention", "blocked"] },
    "score": { "type": "number", "minimum": 0, "maximum": 100 },
    "summary": {
      "type": "object",
      "required": ["total", "passed", "warnings", "blocked", "missing"],
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "passed": { "type": "integer", "minimum": 0 },
        "warnings": { "type": "integer", "minimum": 0 },
        "blocked": { "type": "integer", "minimum": 0 },
        "missing": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "inputs": {
      "type": "object",
      "required": [
        "plan",
        "report",
        "mutationReport",
        "baselines",
        "workflowAudit",
        "securityAudit",
        "costAudit",
        "runHistory",
        "providerDecisions",
        "providerSetupPlan",
        "providerHandoff",
        "llmDecisions"
      ],
      "properties": {
        "plan": { "type": "boolean" },
        "report": { "type": "boolean" },
        "mutationReport": { "type": "boolean" },
        "baselines": { "type": "boolean" },
        "workflowAudit": { "type": "boolean" },
        "securityAudit": { "type": "boolean" },
        "costAudit": { "type": "boolean" },
        "runHistory": { "type": "boolean" },
        "providerDecisions": { "type": "boolean" },
        "providerSetupPlan": { "type": "boolean" },
        "providerHandoff": { "type": "boolean" },
        "llmDecisions": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "gates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "category", "status", "title", "message", "evidence", "artifacts", "nextActions"],
        "properties": {
          "id": { "type": "string" },
          "category": {
            "enum": ["config", "planning", "deterministic", "baselines", "mutation", "workflow", "security", "provider", "llm", "cost", "history"]
          },
          "status": { "enum": ["passed", "warning", "blocked", "missing"] },
          "title": { "type": "string" },
          "message": { "type": "string" },
          "evidence": { "type": "array", "items": { "type": "string" } },
          "artifacts": { "type": "array", "items": { "type": "string" } },
          "nextActions": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    },
    "nextActions": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
