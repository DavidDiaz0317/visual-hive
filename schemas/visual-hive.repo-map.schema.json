{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://visual-hive.dev/schemas/visual-hive.repo-map.schema.json",
  "title": "Visual Hive Repo Map",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "generatedAt",
    "repoRoot",
    "project",
    "packages",
    "scripts",
    "sourceSummary",
    "selectors",
    "routes",
    "workflows",
    "testTools",
    "targetHints",
    "riskSignals",
    "coverageGaps",
    "recommendations"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "generatedAt": {
      "type": "string"
    },
    "repoRoot": {
      "type": "string"
    },
    "outputResource": {
      "$ref": "#/$defs/outputResource"
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "packageManager",
        "workspaces",
        "frameworks"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "packageManager": {
          "enum": [
            "npm",
            "pnpm",
            "yarn",
            "unknown"
          ]
        },
        "workspaces": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "frameworks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "packages": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/packageInfo"
      }
    },
    "scripts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/scriptInfo"
      }
    },
    "sourceSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scannedFiles",
        "truncated",
        "extensions"
      ],
      "properties": {
        "scannedFiles": {
          "type": "integer",
          "minimum": 0
        },
        "truncated": {
          "type": "boolean"
        },
        "extensions": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "selectors": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/selectorHint"
      }
    },
    "routes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/routeHint"
      }
    },
    "workflows": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/workflowHint"
      }
    },
    "testTools": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "targetHints": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/targetHint"
      }
    },
    "riskSignals": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/riskSignal"
      }
    },
    "coverageGaps": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/coverageGap"
      }
    },
    "visualMap": {
      "$ref": "#/$defs/visualMap"
    },
    "recommendations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "outputResource": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifactPath",
        "evidenceResourceId",
        "evidenceResourceUri",
        "evidenceResourceTitle",
        "evidenceResourceDescription"
      ],
      "properties": {
        "artifactPath": {
          "const": ".visual-hive/repo-map.json"
        },
        "evidenceResourceId": {
          "const": "repo-map"
        },
        "evidenceResourceUri": {
          "const": "visual-hive://repo-map"
        },
        "evidenceResourceTitle": {
          "type": "string"
        },
        "evidenceResourceDescription": {
          "type": "string"
        },
        "evidenceReadToolName": {
          "const": "visual_hive_read_repo_map"
        }
      }
    },
    "packageInfo": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "workspaces",
        "scripts",
        "dependencyNames"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "private": {
          "type": "boolean"
        },
        "workspaces": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "scripts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/scriptInfo"
          }
        },
        "dependencyNames": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "scriptInfo": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packagePath",
        "name",
        "command"
      ],
      "properties": {
        "packagePath": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "command": {
          "type": "string"
        }
      }
    },
    "selectorHint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "selector",
        "sourceFile",
        "occurrences"
      ],
      "properties": {
        "selector": {
          "type": "string"
        },
        "sourceFile": {
          "type": "string"
        },
        "occurrences": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "routeHint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "route",
        "sourceFile",
        "occurrences"
      ],
      "properties": {
        "route": {
          "type": "string"
        },
        "sourceFile": {
          "type": "string"
        },
        "occurrences": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "workflowHint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "triggers",
        "permissions",
        "usesPullRequestTarget",
        "usesSecrets",
        "uploadsArtifacts",
        "visualHiveRelated"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "triggers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "permissions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "usesPullRequestTarget": {
          "type": "boolean"
        },
        "usesSecrets": {
          "type": "boolean"
        },
        "uploadsArtifacts": {
          "type": "boolean"
        },
        "visualHiveRelated": {
          "type": "boolean"
        }
      }
    },
    "targetHint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "confidence",
        "evidence"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "kind": {
          "enum": [
            "command",
            "commandGroup",
            "storybook",
            "deployPreview",
            "url"
          ]
        },
        "confidence": {
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "command": {
          "type": "string"
        },
        "url": {
          "type": "string"
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "riskSignal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "severity",
        "message",
        "evidence",
        "recommendation"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "severity": {
          "enum": [
            "info",
            "warning",
            "high"
          ]
        },
        "message": {
          "type": "string"
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "recommendation": {
          "type": "string"
        }
      }
    },
    "coverageGap": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "layer",
        "severity",
        "message",
        "suggestedArtifact"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "layer": {
          "type": "integer",
          "minimum": 0
        },
        "severity": {
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "message": {
          "type": "string"
        },
        "suggestedArtifact": {
          "type": "string"
        }
      }
    },
    "visualMap": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "generatedAt",
        "summary",
        "lifecycle",
        "nodes",
        "edges",
        "findings"
      ],
      "properties": {
        "schemaVersion": {
          "const": 1
        },
        "generatedAt": {
          "type": "string"
        },
        "summary": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "nodes",
            "edges",
            "routes",
            "components",
            "contracts",
            "screenshots",
            "mutations",
            "activeFindings"
          ],
          "properties": {
            "nodes": { "type": "integer", "minimum": 0 },
            "edges": { "type": "integer", "minimum": 0 },
            "routes": { "type": "integer", "minimum": 0 },
            "components": { "type": "integer", "minimum": 0 },
            "contracts": { "type": "integer", "minimum": 0 },
            "screenshots": { "type": "integer", "minimum": 0 },
            "mutations": { "type": "integer", "minimum": 0 },
            "activeFindings": { "type": "integer", "minimum": 0 }
          }
        },
        "lifecycle": {
          "const": "File -> Component -> Layout -> Route -> State -> Viewport -> Target -> Contract -> Screenshot -> Mutation -> Issue"
        },
        "nodes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/visualMapNode"
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/visualMapEdge"
          }
        },
        "findings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/visualMapFinding"
          }
        }
      }
    },
    "visualMapNode": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "label",
        "status",
        "provenance",
        "sourceFiles",
        "routes",
        "states",
        "viewports",
        "selectors",
        "targetIds",
        "contractIds",
        "screenshotNames",
        "mutationOperators",
        "coverageGapIds"
      ],
      "properties": {
        "id": { "type": "string" },
        "kind": {
          "enum": [
            "file",
            "component",
            "layout",
            "route",
            "state",
            "viewport",
            "target",
            "contract",
            "screenshot",
            "mutation",
            "selector",
            "coverage_gap"
          ]
        },
        "label": { "type": "string" },
        "status": {
          "enum": [
            "active",
            "stale",
            "unverified",
            "conflicted"
          ]
        },
        "provenance": {
          "$ref": "#/$defs/visualMapProvenance"
        },
        "sourceFiles": { "type": "array", "items": { "type": "string" } },
        "routes": { "type": "array", "items": { "type": "string" } },
        "states": { "type": "array", "items": { "type": "string" } },
        "viewports": { "type": "array", "items": { "type": "string" } },
        "selectors": { "type": "array", "items": { "type": "string" } },
        "targetIds": { "type": "array", "items": { "type": "string" } },
        "contractIds": { "type": "array", "items": { "type": "string" } },
        "screenshotNames": { "type": "array", "items": { "type": "string" } },
        "mutationOperators": { "type": "array", "items": { "type": "string" } },
        "coverageGapIds": { "type": "array", "items": { "type": "string" } }
      }
    },
    "visualMapProvenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "confidence",
        "generatedAt",
        "firstSeen"
      ],
      "properties": {
        "source": {
          "enum": [
            "static",
            "config",
            "runtime",
            "derived"
          ]
        },
        "confidence": {
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "sourceFile": { "type": "string" },
        "generatedAt": { "type": "string" },
        "firstSeen": { "type": "string" },
        "lastValidated": { "type": "string" }
      }
    },
    "visualMapEdge": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "from",
        "to",
        "relation",
        "evidence",
        "confidence"
      ],
      "properties": {
        "id": { "type": "string" },
        "from": { "type": "string" },
        "to": { "type": "string" },
        "relation": {
          "enum": [
            "declares",
            "renders",
            "uses_selector",
            "targets",
            "covers_route",
            "captures",
            "uses_viewport",
            "maps_mutation",
            "has_gap",
            "impacts",
            "validated_by"
          ]
        },
        "evidence": { "type": "array", "items": { "type": "string" } },
        "confidence": {
          "enum": [
            "high",
            "medium",
            "low"
          ]
        }
      }
    },
    "visualMapFinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "fingerprint",
        "status",
        "severity",
        "message",
        "nodeIds",
        "evidence"
      ],
      "properties": {
        "id": { "type": "string" },
        "fingerprint": { "type": "string" },
        "status": {
          "enum": [
            "active",
            "stale",
            "unverified",
            "conflicted"
          ]
        },
        "severity": {
          "enum": [
            "info",
            "warning",
            "high"
          ]
        },
        "message": { "type": "string" },
        "nodeIds": { "type": "array", "items": { "type": "string" } },
        "evidence": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
