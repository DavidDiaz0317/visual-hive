{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://visual-hive.dev/schemas/visual-hive.repo-map.schema.json",
  "title": "Visual Hive Repo Map",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "generatedAt",
    "repoRoot",
    "project",
    "packages",
    "scripts",
    "sourceSummary",
    "selectors",
    "routes",
    "workflows",
    "testTools",
    "targetHints",
    "riskSignals",
    "coverageGaps",
    "recommendations"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "generatedAt": {
      "type": "string"
    },
    "repoRoot": {
      "type": "string"
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "packageManager",
        "workspaces",
        "frameworks"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "packageManager": {
          "enum": [
            "npm",
            "pnpm",
            "yarn",
            "unknown"
          ]
        },
        "workspaces": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "frameworks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "packages": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/packageInfo"
      }
    },
    "scripts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/scriptInfo"
      }
    },
    "sourceSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scannedFiles",
        "truncated",
        "extensions"
      ],
      "properties": {
        "scannedFiles": {
          "type": "integer",
          "minimum": 0
        },
        "truncated": {
          "type": "boolean"
        },
        "extensions": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "selectors": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/selectorHint"
      }
    },
    "routes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/routeHint"
      }
    },
    "workflows": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/workflowHint"
      }
    },
    "testTools": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "targetHints": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/targetHint"
      }
    },
    "riskSignals": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/riskSignal"
      }
    },
    "coverageGaps": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/coverageGap"
      }
    },
    "recommendations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "packageInfo": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "workspaces",
        "scripts",
        "dependencyNames"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "private": {
          "type": "boolean"
        },
        "workspaces": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "scripts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/scriptInfo"
          }
        },
        "dependencyNames": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "scriptInfo": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packagePath",
        "name",
        "command"
      ],
      "properties": {
        "packagePath": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "command": {
          "type": "string"
        }
      }
    },
    "selectorHint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "selector",
        "sourceFile",
        "occurrences"
      ],
      "properties": {
        "selector": {
          "type": "string"
        },
        "sourceFile": {
          "type": "string"
        },
        "occurrences": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "routeHint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "route",
        "sourceFile",
        "occurrences"
      ],
      "properties": {
        "route": {
          "type": "string"
        },
        "sourceFile": {
          "type": "string"
        },
        "occurrences": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "workflowHint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "triggers",
        "permissions",
        "usesPullRequestTarget",
        "usesSecrets",
        "uploadsArtifacts",
        "visualHiveRelated"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "triggers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "permissions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "usesPullRequestTarget": {
          "type": "boolean"
        },
        "usesSecrets": {
          "type": "boolean"
        },
        "uploadsArtifacts": {
          "type": "boolean"
        },
        "visualHiveRelated": {
          "type": "boolean"
        }
      }
    },
    "targetHint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "confidence",
        "evidence"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "kind": {
          "enum": [
            "command",
            "commandGroup",
            "storybook",
            "deployPreview",
            "url"
          ]
        },
        "confidence": {
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "command": {
          "type": "string"
        },
        "url": {
          "type": "string"
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "riskSignal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "severity",
        "message",
        "evidence",
        "recommendation"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "severity": {
          "enum": [
            "info",
            "warning",
            "high"
          ]
        },
        "message": {
          "type": "string"
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "recommendation": {
          "type": "string"
        }
      }
    },
    "coverageGap": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "layer",
        "severity",
        "message",
        "suggestedArtifact"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "layer": {
          "type": "integer",
          "minimum": 0
        },
        "severity": {
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "message": {
          "type": "string"
        },
        "suggestedArtifact": {
          "type": "string"
        }
      }
    }
  }
}
