{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://visual-hive.dev/schemas/visual-hive.baseline-rejections.schema.json",
  "title": "Visual Hive Baseline Rejection Log",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "rejections"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "rejections": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "schemaVersion",
          "rejectedAt",
          "contractId",
          "screenshotName",
          "route",
          "viewport",
          "sourceStatus",
          "actualPath",
          "baselinePath"
        ],
        "properties": {
          "schemaVersion": { "const": 1 },
          "rejectedAt": { "type": "string" },
          "contractId": { "type": "string", "minLength": 1 },
          "screenshotName": { "type": "string", "minLength": 1 },
          "route": { "type": "string" },
          "viewport": { "type": "string", "minLength": 1 },
          "sourceStatus": { "enum": ["passed", "failed", "created", "missing_baseline"] },
          "actualPath": { "type": "string", "minLength": 1 },
          "baselinePath": { "type": "string", "minLength": 1 },
          "diffPath": { "type": "string" },
          "reason": { "type": "string" }
        }
      }
    }
  }
}
