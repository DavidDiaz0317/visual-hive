{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://visual-hive.dev/schemas/visual-hive.issues.schema.json",
  "title": "Visual Hive Issue Candidates",
  "type": "object",
  "required": ["schemaVersion", "generatedAt", "project", "externalCallsMade", "networkCallsMade", "sourceArtifacts", "summary", "issues"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": "visual-hive.issues.v1" },
    "generatedAt": { "type": "string" },
    "project": { "type": "string" },
    "externalCallsMade": { "const": 0 },
    "networkCallsMade": { "const": 0 },
    "lifecycle": { "$ref": "#/$defs/lifecycle" },
    "sourceArtifacts": { "type": "object", "additionalProperties": { "type": "string" } },
    "summary": {
      "type": "object",
      "required": ["total", "openCandidates", "updateCandidates", "resolvedCandidates", "suppressed", "blocked", "byKind", "bySeverity"],
      "additionalProperties": false,
      "properties": {
        "total": { "type": "number" },
        "openCandidates": { "type": "number" },
        "updateCandidates": { "type": "number" },
        "resolvedCandidates": { "type": "number" },
        "suppressed": { "type": "number" },
        "blocked": { "type": "number" },
        "byKind": { "type": "object", "additionalProperties": { "type": "number" } },
        "bySeverity": { "type": "object", "additionalProperties": { "type": "number" } }
      }
    },
    "issues": {
      "type": "array",
      "items": { "$ref": "#/$defs/issue" }
    }
  },
  "$defs": {
    "lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["owner", "standaloneIssueWrites", "reason"],
      "properties": {
        "owner": { "enum": ["visual-hive", "hive"] },
        "standaloneIssueWrites": { "enum": ["allowed", "suppressed"] },
        "reason": { "type": "string" }
      }
    },
    "issue": {
      "type": "object",
      "required": [
        "issueKind",
        "severity",
        "status",
        "dedupeFingerprint",
        "title",
        "labels",
        "body",
        "owningAgentHint",
        "sourceArtifacts",
        "affected",
        "validationCommand",
        "guardrails"
      ],
      "additionalProperties": false,
      "properties": {
        "issueKind": {
          "enum": [
            "setup_needed",
            "map_drift",
            "missing_visual_coverage",
            "test_adequacy_gap",
            "weak_visual_test",
            "stale_baseline",
            "baseline_churn",
            "visual_regression",
            "selector_contract_failure",
            "screenshot_diff",
            "mutation_survivor",
            "workflow_safety",
            "provider_governance",
            "protected_target_blocked",
            "external_repo_onboarding"
          ]
        },
        "severity": { "enum": ["low", "medium", "high", "critical"] },
        "status": { "enum": ["open_candidate", "update_candidate", "resolved_candidate", "suppressed", "blocked"] },
        "dedupeFingerprint": { "type": "string" },
        "publicationRole": { "enum": ["canonical", "derivative", "aggregate"] },
        "rootCauseKey": { "type": "string", "maxLength": 512, "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9._~:/,+-]|%[0-9A-Fa-f]{2})*$" },
        "blockedByRootKeys": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "maxLength": 512, "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9._~:/,+-]|%[0-9A-Fa-f]{2})*$" }
        },
        "title": { "type": "string" },
        "labels": { "type": "array", "items": { "type": "string" } },
        "body": { "type": "string" },
        "owningAgentHint": {
          "enum": [
            "visual-hive/setup",
            "visual-hive/map",
            "visual-hive/test-creator",
            "visual-hive/test-maintainer",
            "visual-hive/mutation",
            "hive/quality",
            "hive/ci",
            "hive/architect"
          ]
        },
        "sourceArtifacts": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "affected": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "route": { "type": "string" },
              "component": { "type": "string" },
              "contractId": { "type": "string" },
              "selector": { "type": "string" },
              "viewport": { "type": "string" },
              "targetId": { "type": "string" }
            }
          }
        },
        "reproductionCommand": { "type": "string" },
        "validationCommand": { "type": "string" },
        "linkedEvidencePacket": { "type": "string" },
        "linkedRepoMap": { "type": "string" },
        "linkedVisualGraph": { "type": "string" },
        "linkedVisualImpact": { "type": "string" },
        "linkedMutationReport": { "type": "string" },
        "linkedHandoff": { "type": "string" },
        "linkedHiveExport": { "type": "string" },
        "linkedKnowledgeGraph": { "type": "string" },
        "linkedAgentPacket": { "type": "string" },
        "guardrails": { "type": "array", "items": { "type": "string" } },
        "suppressedReason": { "type": "string" },
        "suppressionExpiresAt": { "type": "string" }
      },
      "dependentRequired": {
        "publicationRole": ["rootCauseKey", "blockedByRootKeys"],
        "rootCauseKey": ["publicationRole", "blockedByRootKeys"],
        "blockedByRootKeys": ["publicationRole", "rootCauseKey"]
      },
      "allOf": [
        {
          "if": { "properties": { "publicationRole": { "const": "aggregate" } }, "required": ["publicationRole"] },
          "then": {
            "properties": {
              "issueKind": { "const": "external_repo_onboarding" },
              "blockedByRootKeys": { "minItems": 1 }
            }
          }
        },
        {
          "if": { "properties": { "publicationRole": { "enum": ["canonical", "derivative"] } }, "required": ["publicationRole"] },
          "then": { "properties": { "blockedByRootKeys": { "maxItems": 0 } } }
        },
        {
          "if": { "properties": { "publicationRole": { "const": "derivative" } }, "required": ["publicationRole"] },
          "then": { "properties": { "issueKind": { "enum": ["missing_visual_coverage", "weak_visual_test", "external_repo_onboarding"] } } }
        },
        {
          "oneOf": [
            { "properties": { "issueKind": { "const": "setup_needed" }, "owningAgentHint": { "const": "visual-hive/setup" } } },
            { "properties": { "issueKind": { "const": "map_drift" }, "owningAgentHint": { "const": "visual-hive/map" } } },
            { "properties": { "issueKind": { "const": "missing_visual_coverage" }, "owningAgentHint": { "enum": ["visual-hive/test-creator", "visual-hive/map"] } } },
            { "properties": { "issueKind": { "const": "test_adequacy_gap" }, "owningAgentHint": { "const": "visual-hive/test-creator" } } },
            { "properties": { "issueKind": { "const": "weak_visual_test" }, "owningAgentHint": { "const": "visual-hive/test-maintainer" } } },
            { "properties": { "issueKind": { "const": "stale_baseline" }, "owningAgentHint": { "const": "visual-hive/test-maintainer" } } },
            { "properties": { "issueKind": { "const": "baseline_churn" }, "owningAgentHint": { "const": "visual-hive/test-maintainer" } } },
            { "properties": { "issueKind": { "const": "visual_regression" }, "owningAgentHint": { "const": "hive/quality" } } },
            { "properties": { "issueKind": { "const": "selector_contract_failure" }, "owningAgentHint": { "const": "visual-hive/test-maintainer" } } },
            { "properties": { "issueKind": { "const": "screenshot_diff" }, "owningAgentHint": { "enum": ["hive/quality", "visual-hive/test-maintainer"] } } },
            { "properties": { "issueKind": { "const": "mutation_survivor" }, "owningAgentHint": { "const": "visual-hive/mutation" } } },
            { "properties": { "issueKind": { "const": "workflow_safety" }, "owningAgentHint": { "const": "hive/ci" } } },
            { "properties": { "issueKind": { "const": "provider_governance" }, "owningAgentHint": { "const": "hive/ci" } } },
            { "properties": { "issueKind": { "const": "protected_target_blocked" }, "owningAgentHint": { "const": "hive/ci" } } },
            { "properties": { "issueKind": { "const": "external_repo_onboarding" }, "owningAgentHint": { "enum": ["visual-hive/setup", "hive/quality"] } } }
          ]
        }
      ]
    }
  }
}
