{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://visual-hive.dev/schemas/visual-hive.mutation-report.schema.json",
  "title": "Visual Hive Mutation Report",
  "type": "object",
  "required": [
    "schemaVersion",
    "project",
    "generatedAt",
    "minScore",
    "score",
    "killed",
    "total",
    "results"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": 2
    },
    "project": {
      "type": "string"
    },
    "generatedAt": {
      "type": "string"
    },
    "outputResource": {
      "$ref": "#/$defs/outputResource"
    },
    "minScore": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "killed": {
      "type": "integer",
      "minimum": 0
    },
    "total": {
      "type": "integer",
      "minimum": 0
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "operator",
          "status",
          "killed",
          "applicable",
          "contractIds",
          "durationMs",
          "errors"
        ],
        "additionalProperties": false,
        "properties": {
          "operator": {
            "type": "string"
          },
          "status": {
            "enum": [
              "killed",
              "survived",
              "not_applicable",
              "error"
            ]
          },
          "killed": {
            "type": "boolean"
          },
          "applicable": {
            "type": "boolean"
          },
          "contractIds": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "affected": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/affectedSurface"
            }
          },
          "expectedFailureKinds": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "failureKind": {
            "type": "string"
          },
          "failedAssertion": {
            "type": "string"
          },
          "durationMs": {
            "type": "number",
            "minimum": 0
          },
          "errors": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "artifacts": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "validationCommand": {
            "type": "string"
          },
          "suggestedMissingTest": {
            "type": "string"
          },
          "mutationMode": {
            "enum": [
              "runtime",
              "fixture",
              "source"
            ]
          },
          "sourceMutation": {
            "type": "boolean"
          }
        }
      }
    }
  },
  "$defs": {
    "affectedSurface": {
      "type": "object",
      "required": [
        "contractId"
      ],
      "additionalProperties": false,
      "properties": {
        "contractId": {
          "type": "string"
        },
        "targetId": {
          "type": "string"
        },
        "route": {
          "type": "string"
        },
        "component": {
          "type": "string"
        },
        "viewport": {
          "type": "string"
        }
      }
    },
    "outputResource": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "artifactPath",
        "evidenceResourceId",
        "evidenceResourceUri",
        "evidenceResourceTitle",
        "evidenceResourceDescription",
        "evidenceReadToolName"
      ],
      "properties": {
        "artifactPath": {
          "const": ".visual-hive/mutation-report.json"
        },
        "evidenceResourceId": {
          "const": "mutation-report"
        },
        "evidenceResourceUri": {
          "const": "visual-hive://mutation-report"
        },
        "evidenceResourceTitle": {
          "type": "string"
        },
        "evidenceResourceDescription": {
          "type": "string"
        },
        "evidenceReadToolName": {
          "const": "visual_hive_read_mutation_report"
        }
      }
    }
  }
}
