{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://visual-hive.dev/schemas/visual-hive.task-context.schema.json",
  "title": "Visual Hive Task Context v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "digestAlgorithm", "generatedAt", "taskId", "repository", "issue", "assets", "imageReferences", "graphCandidates", "profiles", "obligations", "sourceContext", "safety", "contextDigest"],
  "properties": {
    "schemaVersion": { "const": "visual-hive.task-context.v1" },
    "digestAlgorithm": { "const": "visual-hive.canonical-json.sha256.v1" },
    "generatedAt": { "$ref": "#/$defs/timestamp" },
    "taskId": { "$ref": "#/$defs/boundedId" },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "repositoryFingerprint", "baseSha"],
      "properties": {
        "name": { "$ref": "#/$defs/repository" },
        "repositoryId": { "type": "string", "minLength": 1, "maxLength": 128 },
        "repositoryFingerprint": { "$ref": "#/$defs/sha256" },
        "baseSha": { "$ref": "#/$defs/gitCommit" },
        "ref": { "type": "string", "minLength": 1, "maxLength": 1024 }
      }
    },
    "issue": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "externalId", "problemStatement", "problemStatementSha256"],
      "properties": {
        "source": { "enum": ["swebench_multimodal", "github", "fixture", "other"] },
        "externalId": { "type": "string", "minLength": 1, "maxLength": 512 },
        "title": { "type": "string", "minLength": 1, "maxLength": 1024 },
        "problemStatement": { "type": "string", "minLength": 1, "maxLength": 120000 },
        "problemStatementSha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "assets": { "type": "array", "maxItems": 64, "items": { "$ref": "#/$defs/asset" } },
    "imageReferences": { "type": "array", "maxItems": 64, "items": { "$ref": "#/$defs/imageReference" } },
    "graphCandidates": { "type": "array", "maxItems": 256, "items": { "$ref": "#/$defs/graphCandidate" } },
    "profiles": { "type": "array", "maxItems": 64, "items": { "$ref": "#/$defs/profile" } },
    "obligations": { "type": "array", "maxItems": 256, "items": { "$ref": "#/$defs/obligation" } },
    "sourceContext": {
      "type": "object",
      "additionalProperties": false,
      "required": ["digest", "files", "omittedPaths", "truncated"],
      "properties": {
        "digest": { "$ref": "#/$defs/sha256" },
        "files": {
          "type": "array",
          "maxItems": 512,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "sha256", "size", "classification"],
            "properties": {
              "path": { "$ref": "#/$defs/relativePath" },
              "sha256": { "$ref": "#/$defs/sha256" },
              "size": { "type": "integer", "minimum": 0, "maximum": 8388608 },
              "classification": { "enum": ["source", "test", "config", "documentation"] }
            }
          }
        },
        "omittedPaths": { "type": "integer", "minimum": 0 },
        "truncated": { "type": "boolean" }
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": ["containsGoldPatch", "containsTestPatch", "containsGraderTests", "externalCallsMade", "networkCallsMade", "writesMade"],
      "properties": {
        "containsGoldPatch": { "const": false },
        "containsTestPatch": { "const": false },
        "containsGraderTests": { "const": false },
        "externalCallsMade": { "const": 0 },
        "networkCallsMade": { "const": 0 },
        "writesMade": { "const": 0 }
      }
    },
    "contextDigest": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "gitCommit": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
    "boundedId": { "type": "string", "minLength": 1, "maxLength": 256, "pattern": "^[A-Za-z0-9][A-Za-z0-9._:@+~-]*$" },
    "repository": { "type": "string", "minLength": 3, "maxLength": 512, "pattern": "^(?!\\.\\.?/)(?![^/]+/\\.\\.?$)[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$" },
    "relativePath": { "type": "string", "minLength": 1, "maxLength": 1024, "pattern": "^(?!/)(?![A-Za-z]:)(?!.*[:\\\\\\u0000-\\u001f\\u007f])(?!.*(?:^|/)\\.\\.?(?:/|$))(?!.*//)(?!.*[. ](?:/|$))(?!(?:.*\/)?(?:con|prn|aux|nul|com[1-9]|lpt[1-9])(?:\\.|/|$)).+$" },
    "timestamp": { "type": "string", "format": "date-time" },
    "shortText": { "type": "string", "minLength": 1, "maxLength": 2048, "pattern": "\\S" },
    "assetRole": { "enum": ["problem", "expected", "current", "baseline", "actual", "diff", "reference", "frame"] },
    "mediaType": { "enum": ["image/png", "image/jpeg", "image/webp", "image/gif"] },
    "region": {
      "type": "object",
      "additionalProperties": false,
      "required": ["regionId", "x", "y", "width", "height"],
      "properties": {
        "regionId": { "$ref": "#/$defs/boundedId" },
        "label": { "type": "string", "minLength": 1, "maxLength": 512 },
        "x": { "type": "integer", "minimum": 0 },
        "y": { "type": "integer", "minimum": 0 },
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 }
      }
    },
    "asset": {
      "type": "object",
      "additionalProperties": false,
      "dependentRequired": { "width": ["height"], "height": ["width"] },
      "required": ["assetId", "role", "path", "mediaType", "sha256", "size", "provenance", "regions"],
      "properties": {
        "assetId": { "$ref": "#/$defs/boundedId" },
        "role": { "$ref": "#/$defs/assetRole" },
        "path": { "$ref": "#/$defs/relativePath" },
        "mediaType": { "$ref": "#/$defs/mediaType" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "size": { "type": "integer", "minimum": 1, "maximum": 33554432 },
        "width": { "type": "integer", "minimum": 1, "maximum": 32768 },
        "height": { "type": "integer", "minimum": 1, "maximum": 32768 },
        "provenance": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "sourceId"],
          "properties": {
            "kind": { "enum": ["benchmark", "issue_attachment", "capture", "baseline", "generated_diff", "fixture"] },
            "sourceId": { "type": "string", "minLength": 1, "maxLength": 2048 },
            "sourceDigest": { "$ref": "#/$defs/sha256" },
            "capturedAt": { "$ref": "#/$defs/timestamp" },
            "runId": { "$ref": "#/$defs/boundedId" }
          }
        },
        "regions": { "type": "array", "maxItems": 128, "default": [], "items": { "$ref": "#/$defs/region" } }
      }
    },
    "imageReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["position", "assetId", "role"],
      "properties": {
        "position": { "type": "integer", "minimum": 0, "maximum": 63 },
        "assetId": { "$ref": "#/$defs/boundedId" },
        "role": { "$ref": "#/$defs/assetRole" },
        "caption": { "type": "string", "minLength": 1, "maxLength": 4096 }
      }
    },
    "sourceSpan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "startLine", "endLine"],
      "properties": {
        "path": { "$ref": "#/$defs/relativePath" },
        "startLine": { "type": "integer", "minimum": 1 },
        "endLine": { "type": "integer", "minimum": 1 },
        "startColumn": { "type": "integer", "minimum": 1 },
        "endColumn": { "type": "integer", "minimum": 1 }
      }
    },
    "graphCandidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["nodeId", "kind", "label", "score", "reasons", "sourceSpans"],
      "properties": {
        "nodeId": { "$ref": "#/$defs/boundedId" },
        "kind": { "enum": ["file", "symbol", "component", "route", "selector", "contract", "flow", "mutation"] },
        "label": { "$ref": "#/$defs/shortText" },
        "score": { "type": "number", "minimum": 0, "maximum": 1 },
        "reasons": { "type": "array", "maxItems": 32, "items": { "$ref": "#/$defs/shortText" } },
        "sourceSpans": { "type": "array", "maxItems": 64, "items": { "$ref": "#/$defs/sourceSpan" } }
      }
    },
    "viewport": {
      "type": "object",
      "additionalProperties": false,
      "required": ["viewportId", "width", "height", "deviceScaleFactor"],
      "properties": {
        "viewportId": { "$ref": "#/$defs/boundedId" },
        "width": { "type": "integer", "minimum": 1, "maximum": 16384 },
        "height": { "type": "integer", "minimum": 1, "maximum": 16384 },
        "deviceScaleFactor": { "type": "number", "exclusiveMinimum": 0, "maximum": 8, "default": 1 }
      }
    },
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profileId", "profileDigest", "targetId", "requestKinds", "contractIds", "routes", "scenarioIds", "viewports", "validationCommandId"],
      "properties": {
        "profileId": { "$ref": "#/$defs/boundedId" },
        "profileDigest": { "$ref": "#/$defs/sha256" },
        "targetId": { "$ref": "#/$defs/boundedId" },
        "requestKinds": { "type": "array", "minItems": 1, "maxItems": 3, "items": { "enum": ["reproduction", "capture", "patch_validation"] } },
        "contractIds": { "type": "array", "maxItems": 256, "items": { "$ref": "#/$defs/boundedId" } },
        "routes": { "type": "array", "maxItems": 128, "items": { "type": "string", "minLength": 1, "maxLength": 2048 } },
        "scenarioIds": { "type": "array", "maxItems": 128, "items": { "$ref": "#/$defs/boundedId" } },
        "viewports": { "type": "array", "minItems": 1, "maxItems": 32, "items": { "$ref": "#/$defs/viewport" } },
        "validationCommandId": { "$ref": "#/$defs/boundedId" }
      }
    },
    "obligation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["obligationId", "description", "sourceAssetIds", "mappedContractIds", "assertionKind", "authority", "confidence", "status"],
      "properties": {
        "obligationId": { "$ref": "#/$defs/boundedId" },
        "description": { "type": "string", "minLength": 1, "maxLength": 60000, "pattern": "\\S" },
        "sourceAssetIds": { "type": "array", "maxItems": 64, "items": { "$ref": "#/$defs/boundedId" } },
        "mappedContractIds": { "type": "array", "maxItems": 128, "items": { "$ref": "#/$defs/boundedId" } },
        "route": { "type": "string", "minLength": 1, "maxLength": 2048 },
        "state": { "type": "string", "minLength": 1, "maxLength": 1024 },
        "viewportId": { "$ref": "#/$defs/boundedId" },
        "assertionKind": { "enum": ["dom", "aria", "text", "behavior", "pixel_region", "visual_relation"] },
        "authority": { "enum": ["deterministic", "advisory"] },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "status": { "enum": ["specified", "mapped", "executed", "passed", "failed", "blocked", "unresolved"] },
        "unresolvedReason": { "$ref": "#/$defs/shortText" }
      }
    }
  }
}
