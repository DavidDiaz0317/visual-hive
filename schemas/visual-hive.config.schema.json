{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://visual-hive.dev/schemas/visual-hive.config.schema.json",
  "title": "Visual Hive Config",
  "type": "object",
  "required": ["project", "targets", "contracts"],
  "additionalProperties": false,
  "properties": {
    "project": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "type": { "enum": ["react-vite", "nextjs", "static", "dashboard", "custom"], "default": "custom" },
        "defaultBranch": { "type": "string", "default": "main" }
      }
    },
    "targets": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "oneOf": [
          { "$ref": "#/$defs/urlTarget" },
          { "$ref": "#/$defs/commandTarget" },
          { "$ref": "#/$defs/commandGroupTarget" },
          { "$ref": "#/$defs/protectedTarget" }
        ]
      }
    },
    "contracts": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/contract" } },
    "viewports": { "type": "object", "additionalProperties": { "$ref": "#/$defs/viewport" } },
    "visual": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "maxDiffPixelRatio": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.01 },
        "maxDiffPixels": { "type": "integer", "minimum": 0 },
        "updateSnapshots": { "type": "boolean", "default": false },
        "failOnMissingBaselineInCI": { "type": "boolean", "default": true },
        "snapshotDir": { "$ref": "#/$defs/repoRelativePath", "default": ".visual-hive/snapshots" },
        "artifactDir": { "$ref": "#/$defs/repoRelativePath", "default": ".visual-hive/artifacts" }
      }
    },
    "selection": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "changedFiles": { "type": "array", "items": { "$ref": "#/$defs/changedFileRule" } }
      }
    },
    "mutation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "runOn": { "$ref": "#/$defs/runOn" },
        "minScore": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.7 },
        "operators": {
          "type": "array",
          "items": {
            "oneOf": [
              { "$ref": "#/$defs/mutationOperator" },
              {
                "type": "object",
                "required": ["id"],
                "additionalProperties": false,
                "properties": {
                  "id": { "$ref": "#/$defs/mutationOperator" },
                  "contracts": { "type": "array", "items": { "type": "string" } }
                }
              }
            ]
          }
        }
      }
    },
    "ai": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "provider": { "type": "string", "default": "none" },
        "neverSoleOracle": { "type": "boolean", "const": true },
        "createIssuePrompt": { "type": "boolean", "default": true },
        "maxDailyRuns": { "type": "integer", "minimum": 1, "default": 5 }
      }
    },
    "github": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "issueLabels": { "type": "array", "items": { "type": "string" } },
        "commentMarker": { "type": "string", "default": "<!-- visual-hive-report -->" }
      }
    }
  },
  "$defs": {
    "cost": { "enum": ["cheap", "medium", "expensive"] },
    "severity": { "enum": ["low", "medium", "high", "critical"] },
    "runOn": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "pullRequest": { "type": "boolean", "default": false },
        "schedule": { "type": "boolean", "default": false }
      }
    },
    "viewport": {
      "type": "object",
      "required": ["width", "height"],
      "additionalProperties": false,
      "properties": {
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 }
      }
    },
    "repoRelativePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?![A-Za-z]:)(?![\\\\/])(?!.*(^|[\\\\/])\\.\\.([\\\\/]|$)).+"
    },
    "targetBase": {
      "type": "object",
      "properties": {
        "url": { "type": "string", "format": "uri" },
        "prSafe": { "type": "boolean", "default": false },
        "schedule": { "type": "string" },
        "cost": { "$ref": "#/$defs/cost" }
      }
    },
    "urlTarget": {
      "allOf": [
        { "$ref": "#/$defs/targetBase" },
        {
          "type": "object",
          "required": ["kind", "url"],
          "additionalProperties": false,
          "properties": {
            "kind": { "const": "url" },
            "url": { "type": "string", "format": "uri" },
            "prSafe": { "type": "boolean", "default": false },
            "schedule": { "type": "string" },
            "cost": { "$ref": "#/$defs/cost" }
          }
        }
      ]
    },
    "commandTarget": {
      "type": "object",
      "required": ["kind", "serve", "url"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "command" },
        "install": { "type": "string" },
        "build": { "type": "string" },
        "serve": { "type": "string" },
        "url": { "type": "string", "format": "uri" },
        "prSafe": { "type": "boolean", "default": false },
        "schedule": { "type": "string" },
        "cost": { "$ref": "#/$defs/cost" }
      }
    },
    "service": {
      "type": "object",
      "required": ["name", "command", "url"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "command": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "format": "uri" },
        "healthPath": { "type": "string" },
        "readinessTimeoutMs": { "type": "integer", "minimum": 1 }
      }
    },
    "commandGroupTarget": {
      "type": "object",
      "required": ["kind", "services", "url"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "commandGroup" },
        "setup": { "type": "array", "items": { "type": "string" } },
        "services": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/service" } },
        "teardown": { "type": "array", "items": { "type": "string" } },
        "url": { "type": "string", "format": "uri" },
        "prSafe": { "type": "boolean", "default": false },
        "schedule": { "type": "string" },
        "cost": { "$ref": "#/$defs/cost" }
      }
    },
    "protectedTarget": {
      "type": "object",
      "required": ["kind"],
      "additionalProperties": false,
      "anyOf": [
        { "required": ["url"] },
        {
          "properties": {
            "services": { "type": "array", "minItems": 1 }
          },
          "required": ["services"]
        }
      ],
      "properties": {
        "kind": { "const": "protected" },
        "setup": { "type": "array", "items": { "type": "string" } },
        "services": { "type": "array", "items": { "$ref": "#/$defs/service" } },
        "teardown": { "type": "array", "items": { "type": "string" } },
        "url": { "type": "string", "format": "uri" },
        "prSafe": { "type": "boolean", "default": false },
        "schedule": { "type": "string" },
        "cost": { "$ref": "#/$defs/cost", "default": "expensive" },
        "requiresSecrets": { "type": "array", "items": { "type": "string" } }
      }
    },
    "contract": {
      "type": "object",
      "required": ["id", "description", "target"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "target": { "type": "string", "minLength": 1 },
        "severity": { "$ref": "#/$defs/severity" },
        "runOn": { "$ref": "#/$defs/runOn" },
        "timeoutMs": { "type": "integer", "minimum": 1 },
        "waitFor": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["selector"],
            "additionalProperties": false,
            "properties": {
              "selector": { "type": "string", "minLength": 1 },
              "state": { "enum": ["visible", "attached", "hidden"], "default": "visible" },
              "timeoutMs": { "type": "integer", "minimum": 1, "default": 5000 }
            }
          }
        },
        "failOnConsoleError": { "type": "boolean", "default": false },
        "expectedConsoleErrors": { "type": "array", "items": { "type": "string" } },
        "selectors": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "mustExist": { "type": "array", "items": { "type": "string" } },
            "mustNotExist": { "type": "array", "items": { "type": "string" } },
            "textMustExist": { "type": "array", "items": { "type": "string" } },
            "textMustNotExist": { "type": "array", "items": { "type": "string" } }
          }
        },
        "screenshots": { "type": "array", "items": { "$ref": "#/$defs/screenshot" } }
      }
    },
    "screenshot": {
      "type": "object",
      "required": ["name", "route", "viewport"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "route": { "type": "string", "default": "/" },
        "viewport": { "type": "string", "minLength": 1 },
        "fullPage": { "type": "boolean", "default": true },
        "mask": { "type": "array", "items": { "type": "string" } }
      }
    },
    "changedFileRule": {
      "type": "object",
      "required": ["pattern"],
      "additionalProperties": false,
      "properties": {
        "pattern": { "type": "string", "minLength": 1 },
        "contracts": { "type": "array", "items": { "type": "string" } },
        "risk": { "$ref": "#/$defs/severity" }
      }
    },
    "mutationOperator": {
      "enum": ["hide-critical-button", "force-login-on-demo", "remove-demo-badge", "api-500", "empty-data", "mobile-overflow"]
    }
  }
}
