{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://visual-hive.dev/schemas/visual-hive.provider-setup-plan.schema.json",
  "title": "Visual Hive Provider Setup Plan",
  "type": "object",
  "required": [
    "schemaVersion",
    "project",
    "generatedAt",
    "providerId",
    "label",
    "recommendation",
    "readiness",
    "authorizationRequired",
    "externalCallsMade",
    "configChanges",
    "workflowSteps",
    "safetyChecks",
    "validationCommands",
    "warnings"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "project": {
      "type": "string"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "providerId": {
      "type": "string"
    },
    "label": {
      "type": "string"
    },
    "recommendation": {
      "enum": [
        "use_builtin",
        "keep_disabled",
        "mock_review",
        "trusted_setup_ready",
        "blocked"
      ]
    },
    "readiness": {
      "type": "object",
      "required": [
        "enabled",
        "mode",
        "deterministicRole",
        "availability",
        "requiredEnv",
        "missingEnv",
        "projectIdConfigured",
        "externalUploadAllowed",
        "externalUploadBlockedReasons"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "mode": {
          "enum": [
            "mock",
            "external"
          ]
        },
        "deterministicRole": {
          "enum": [
            "oracle",
            "supplemental"
          ]
        },
        "availability": {
          "type": "string"
        },
        "requiredEnv": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "missingEnv": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "projectIdConfigured": {
          "type": "boolean"
        },
        "externalUploadAllowed": {
          "type": "boolean"
        },
        "externalUploadBlockedReasons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "authorizationRequired": {
      "type": "boolean"
    },
    "externalCallsMade": {
      "const": 0
    },
    "configChanges": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "workflowSteps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "safetyChecks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "validationCommands": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
