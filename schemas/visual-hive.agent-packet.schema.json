    "forbiddenActions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "budgets": {
      "type": "object",
      "required": [
        "maxToolCalls",
        "maxToolResultTokens",
        "maxExternalCostUsd",
        "allowExternalNetwork"
      ],
      "additionalProperties": false,
      "properties": {
        "maxToolCalls": {
          "type": "number"
        },
        "maxToolResultTokens": {
          "type": "number"
        },
        "maxExternalCostUsd": {
          "const": 0
        },
        "allowExternalNetwork": {
          "const": false
        }
      }
    },
    "reproductionCommands": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "artifactPointers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "instructions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "governance": {
      "type": "object",
      "required": [
        "verdictAuthority",
        "agentAuthority",
        "secretPolicy",
        "requireHumanApprovalFor"
      ],
      "additionalProperties": false,
      "properties": {
        "verdictAuthority": {
          "const": "visual_hive"
        },
        "agentAuthority": {
          "const": "advisory_repair_only"
        },
        "secretPolicy": {
          "const": "redacted_values_names_only"
        },
        "requireHumanApprovalFor": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  },
  "$defs": {
    "verdict": {
      "type": "object",
      "required": [
        "visualHiveVerdict",
        "failedBecause",
        "warningBecause",
        "blockedBecause",
        "advisoryOnly"
      ],
      "additionalProperties": false,
      "properties": {
        "visualHiveVerdict": {
          "enum": [
            "passed",
            "failed",
            "warning",
            "blocked",
            "inconclusive"
          ]
        },
        "failedBecause": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "warningBecause": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "blockedBecause": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "advisoryOnly": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "evidenceContribution": {
      "type": "object",
      "required": [
        "key",
        "source",
        "kind",
        "status",
        "gating",
        "authority",
        "reason",
        "artifacts"
      ],
      "additionalProperties": false,
      "properties": {
        "key": {
          "type": "string"
        },
        "source": {
          "enum": [
            "visual_hive",
            "playwright",
            "screenshot_diff",
            "mutation",
            "provider",
            "triage",
            "readiness",
            "coverage",
            "llm",
            "hive",
            "agent"
          ]
        },
        "kind": {
          "type": "string"
        },
        "status": {
          "enum": [
            "passed",
            "failed",
            "warning",
            "blocked",
            "inconclusive",
            "skipped"
          ]
        },
        "gating": {
          "type": "boolean"
        },
        "authority": {
          "enum": [
            "gating",
            "advisory"
          ]
        },
        "mode": {
          "type": "string"
        },
        "contractId": {
          "type": "string"
        },
        "targetId": {
          "type": "string"
        },
        "operator": {
          "type": "string"
        },
        "providerId": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "artifacts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "providerEvidence": {
      "type": "object",
      "required": [
        "providerId",
        "status",
        "deterministicRole",
        "message",
        "artifactCount",
        "missingEnv",
        "externalCallsMade",
        "blockedReasons"
      ],
      "additionalProperties": false,
      "properties": {
        "providerId": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "deterministicRole": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "artifactCount": {
          "type": "number"
        },
        "missingEnv": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "uploadStatus": {
          "type": "string"
        },
        "externalCallsMade": {
          "type": "number",
          "minimum": 0
        },
        "stagedArtifacts": {
          "type": "number",
          "minimum": 0
        },
        "uploadedArtifacts": {
          "type": "number",
          "minimum": 0
        },
        "manifestPath": {
          "type": "string"
        },
        "uploadDirectory": {
          "type": "string"
        },
        "providerUrl": {
          "type": "string"
        },
        "blockedReasons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "runHistorySummary": {
      "type": "object",
      "required": [
        "artifactPath",
        "evidenceResourceId",
        "evidenceResourceUri",
        "evidenceReadToolName",
        "authority",
        "runCount",
        "trendDirection",
        "trendReasons",
        "totalVisualDiffs",
        "totalMissingBaselines",
        "totalCreatedBaselines"
      ],
      "additionalProperties": false,
      "properties": {
        "artifactPath": {
          "const": ".visual-hive/history.json"
        },
        "evidenceResourceId": {
          "const": "run-history"
        },
        "evidenceResourceUri": {
          "const": "visual-hive://run-history"
        },
        "evidenceReadToolName": {
          "const": "visual_hive_read_run_history"
        },
        "authority": {
          "const": "trend_evidence_only"
        },
        "runCount": {
          "type": "number",
          "minimum": 0
        },
        "latestStatus": {
          "enum": [
            "passed",
            "failed"
          ]
        },
        "latestRecordedAt": {
          "type": "string"
        },
        "latestMutationScore": {
          "type": "number"
        },
        "trendDirection": {
          "enum": [
            "improved",
            "regressed",
            "unchanged",
            "unknown"
          ]
        },
        "trendReasons": {
          "type": "array",
          "items": {
            "type": "string"
          }
