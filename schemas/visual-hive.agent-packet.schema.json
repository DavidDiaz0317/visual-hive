{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://visual-hive.dev/schemas/visual-hive.agent-packet.schema.json",
  "title": "Visual Hive Agent Packet",
  "type": "object",
  "required": [
    "schemaVersion",
    "generatedAt",
    "project",
    "profile",
    "objective",
    "sourceArtifacts",
    "verdict",
    "evidenceSummary",
    "allowedTools",
    "forbiddenActions",
    "budgets",
    "reproductionCommands",
    "artifactPointers",
    "instructions",
    "governance"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "visual-hive.agent-packet.v1"
    },
    "generatedAt": {
      "type": "string"
    },
    "project": {
      "type": "string"
    },
    "profile": {
      "enum": [
        "repair_agent",
        "test_creator",
        "review_agent",
        "handoff_agent",
        "provider_specialist"
      ]
    },
    "objective": {
      "type": "string"
    },
    "sourceArtifacts": {
      "type": "object",
      "required": [
        "evidencePacket"
      ],
      "additionalProperties": false,
      "properties": {
        "evidencePacket": {
          "type": "string"
        },
        "handoffPacket": {
          "type": "string"
        },
        "testCreationPlan": {
          "type": "string"
        },
        "runHistory": {
          "type": "string"
        }
      }
    },
    "verdict": {
      "$ref": "#/$defs/verdict"
    },
    "evidenceSummary": {
      "type": "object",
      "required": [
        "gatingContributions",
        "advisoryContributions",
        "workItems",
        "selectedContracts",
        "selectedTargets",
        "providerEvidence"
      ],
      "additionalProperties": false,
      "properties": {
        "gatingContributions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidenceContribution"
          }
        },
        "advisoryContributions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidenceContribution"
          }
        },
        "workItems": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/workItem"
          }
        },
        "selectedContracts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "selectedTargets": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "mutationScore": {
          "type": "number"
        },
        "providerEvidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/providerEvidence"
          }
        },
        "runHistory": {
          "$ref": "#/$defs/runHistorySummary"
        },
        "testingLayers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/testingLayer"
          }
        },
        "testCreationRecommendations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/testCreationRecommendation"
          }
        }
      }
    },
