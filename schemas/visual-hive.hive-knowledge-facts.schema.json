{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://visual-hive.dev/schemas/visual-hive.hive-knowledge-facts.schema.json",
  "title": "Visual Hive Hive Knowledge Facts",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "slug",
      "title",
      "type",
      "layer",
      "confidence",
      "tags",
      "source",
      "body",
      "relatedEvidenceKeys",
      "artifacts"
    ],
    "properties": {
      "slug": {
        "type": "string"
      },
      "title": {
        "type": "string"
      },
      "type": {
        "enum": [
          "pattern",
          "gotcha",
          "decision",
          "regression",
          "test_scaffold",
          "integration",
          "coverage_rule"
        ]
      },
      "layer": {
        "const": "project"
      },
      "confidence": {
        "type": "number",
        "minimum": 0,
        "maximum": 1
      },
      "tags": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "source": {
        "type": "string"
      },
      "body": {
        "type": "string"
      },
      "relatedEvidenceKeys": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "artifacts": {
        "type": "array",
        "items": {
          "type": "string"
        }
      }
    }
  }
}
