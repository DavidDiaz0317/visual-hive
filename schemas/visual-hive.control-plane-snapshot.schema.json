{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://visual-hive.dev/schemas/visual-hive.control-plane-snapshot.schema.json",
  "title": "Visual Hive Control Plane Snapshot",
  "description": "Local-first Control Plane API snapshot. This schema locks the public guidance, runbook, artifact, and navigation surface used by the UI, agents, and smoke tests while allowing nested Visual Hive artifacts to keep their own schemas.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schemaVersion",
    "generatedAt",
    "repoRoot",
    "configPath",
    "configRoot",
    "readOnly",
    "demo",
    "safetyBoundary",
    "overview",
    "guidanceState",
    "navigationBadges",
    "failures",
    "runbook",
    "runProfiles",
    "setupProgress",
    "screenshots",
    "coverage",
    "targets",
    "contracts",
    "providers",
    "workflowTemplates",
    "artifacts"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "generatedAt": {
      "type": "string"
    },
    "repoRoot": {
      "type": "string",
      "minLength": 1
    },
    "configPath": {
      "type": "string",
      "minLength": 1
    },
    "configRoot": {
      "type": "string",
      "minLength": 1
    },
    "readOnly": {
      "type": "boolean"
    },
    "demo": {
      "type": "boolean"
    },
    "safetyBoundary": {
      "type": "string",
      "minLength": 1
    },
    "overview": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "healthScore",
        "healthGrade",
        "deterministicStatus",
        "gatingContributions",
        "advisoryContributions",
        "failedContributions",
        "blockedContributions",
        "failedContracts",
        "createdBaselines",
        "missingBaselines",
        "visualDiffs",
        "consoleErrors",
        "pageErrors",
        "nextActions",
        "explanations"
      ],
      "properties": {
        "healthScore": {
          "type": "number"
        },
        "healthGrade": {
          "enum": [
            "unknown",
            "poor",
            "fair",
            "good",
            "excellent"
          ]
        },
        "deterministicStatus": {
          "enum": [
            "missing",
            "passed",
            "failed"
          ]
        },
        "visualHiveVerdict": {
          "enum": [
            "passed",
            "failed",
            "warning",
            "blocked",
            "inconclusive"
          ]
        },
        "gatingContributions": {
          "type": "number"
        },
        "advisoryContributions": {
          "type": "number"
        },
        "failedContributions": {
          "type": "number"
        },
        "blockedContributions": {
          "type": "number"
        },
        "mutationScore": {
          "type": "number"
        },
        "failedContracts": {
          "type": "number"
        },
        "createdBaselines": {
          "type": "number"
        },
        "missingBaselines": {
          "type": "number"
        },
        "visualDiffs": {
          "type": "number"
        },
        "consoleErrors": {
          "type": "number"
        },
        "pageErrors": {
          "type": "number"
        },
        "pipelineStatus": {
          "enum": [
            "passed",
            "failed",
            "blocked"
          ]
        },
        "pipelineSteps": {
          "type": "number"
        },
        "pipelineFailedSteps": {
          "type": "number"
        },
        "nextActions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "explanations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "guidanceState": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state",
        "title",
        "summary",
        "primaryAction",
        "secondaryActions",
        "blockedReasons",
        "progress",
        "adoptionChecklist"
      ],
      "properties": {
        "state": {
          "enum": [
            "no_config",
            "config_error",
            "plan_needed",
            "run_needed",
            "failures_need_triage",
            "baselines_need_review",
            "mutation_needs_work",
            "readiness_blocked",
            "ready"
          ]
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string"
        },
        "primaryAction": {
          "$ref": "#/$defs/guidanceAction"
        },
        "secondaryActions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/guidanceAction"
          }
        },
        "blockedReasons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "progress": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/guidanceStep"
          }
        },
        "adoptionChecklist": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/adoptionChecklistItem"
          }
        }
      }
    },
    "navigationBadges": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "start",
        "run",
        "review",
        "configure",
        "expert",
        "failures",
        "baselines",
        "risks",
        "setup",
        "providerBlocks"
      ],
      "properties": {
        "start": {
          "type": "number"
        },
        "run": {
          "type": "number"
        },
        "review": {
          "type": "number"
        },
        "configure": {
          "type": "number"
        },
        "expert": {
          "type": "number"
        },
        "failures": {
          "type": "number"
        },
        "baselines": {
          "type": "number"
        },
        "risks": {
          "type": "number"
        },
        "setup": {
          "type": "number"
        },
        "providerBlocks": {
          "type": "number"
        }
      }
    },
    "failures": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/failure"
      }
    },
    "runbook": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "generatedAt",
        "configPath",
        "commands",
        "notes"
      ],
      "properties": {
        "generatedAt": {
          "type": "string"
        },
        "configPath": {
          "type": "string"
        },
        "commands": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/runbookCommand"
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "runProfiles": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/runProfile"
      }
    },
    "setupProgress": {
      "type": "object",
      "additionalProperties": true
    },
    "screenshots": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "coverage": {
      "type": "object",
      "additionalProperties": true
    },
    "targets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "contracts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "providers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "schemaCatalog": {
      "type": "object",
      "additionalProperties": true,
      "description": "Optional schema/catalog verification evidence from .visual-hive/schema-catalog.json. The artifact has its own schema and is surfaced here so the Control Plane can show drift health without rerunning maintenance checks."
    },
    "mcpManifest": {
      "type": "object",
      "additionalProperties": true,
      "description": "Optional first-party MCP manifest evidence from .visual-hive/mcp-manifest.json. Setup-only manifests may expose setup recommendations, setup PR plan, repo map, repo context, artifact index, and MCP manifest resources before a config exists."
    },
    "contextLedger": {
      "type": "object",
      "additionalProperties": true,
      "description": "Optional Context Ledger evidence from .visual-hive/context-ledger.json. Tool calls may include evidenceResources[] so agents can follow every catalog-backed artifact produced by a pipeline step without scraping raw paths."
    },
    "workflowTemplates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/artifact"
      }
    }
  },
  "$defs": {
    "artifact": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "path",
        "kind",
        "contentType",
        "bytes",
        "safeToRender",
        "previewTruncated",
        "previewRedacted",
        "labels"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "kind": {
          "enum": [
            "json",
            "markdown",
            "image",
            "text",
            "typescript",
            "yaml",
            "log",
            "other"
          ]
        },
        "contentType": {
          "type": "string"
        },
        "bytes": {
          "type": "number"
        },
        "safeToRender": {
          "type": "boolean"
        },
        "preview": {
          "type": "string"
        },
        "previewTruncated": {
          "type": "boolean"
        },
        "previewRedacted": {
          "type": "boolean"
        },
        "labels": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "schemaPath": {
          "type": "string"
        },
        "schemaId": {
          "type": "string"
        },
        "evidenceResourceId": {
          "type": "string",
          "enum": [
            "config",
            "latest-plan",
            "plan-lanes",
            "setup-recommendations",
            "setup-pr-plan",
            "repo-map",
