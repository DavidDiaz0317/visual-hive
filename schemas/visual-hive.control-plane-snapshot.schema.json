            "visual_hive_read_setup_issue",
            "visual_hive_read_issue_publish_plan",
            "visual_hive_read_issue_publish_dry_run",
            "visual_hive_read_issue_publish_result",
            "visual_hive_read_pr_comment",
            "visual_hive_read_triage_prompt",
