            "visual_hive_read_pipeline_status",
            "visual_hive_read_schema_catalog",
            "visual_hive_read_mcp_manifest"
          ]
        }
      }
    },
    "guidanceAction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "description",
        "area"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "area": {
          "enum": [
            "start",
            "run",
            "review",
            "configure"
          ]
        },
        "commandId": {
          "type": "string"
        },
        "tone": {
          "enum": [
            "neutral",
            "success",
            "warning",
            "danger",
            "info",
            "amber"
          ]
        },
        "disabledReason": {
          "type": "string"
        }
      }
    },
    "guidanceStep": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "status",
        "description"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "status": {
          "enum": [
            "complete",
            "current",
            "review",
            "blocked",
            "pending"
          ]
        },
        "description": {
          "type": "string"
        },
        "commandId": {
          "type": "string"
        }
      }
    },
    "adoptionChecklistItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "step",
        "status",
        "why",
        "nextAction",
        "area",
        "commandRunnable",
        "expectedArtifacts"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "step": {
          "type": "string"
        },
        "status": {
          "enum": [
            "complete",
            "current",
            "review",
            "blocked",
            "pending"
          ]
        },
        "why": {
          "type": "string"
        },
        "nextAction": {
          "type": "string"
        },
        "area": {
          "enum": [
            "start",
            "run",
            "review",
            "configure"
          ]
        },
        "commandId": {
          "type": "string"
        },
        "commandLabel": {
          "type": "string"
        },
        "command": {
          "type": "string"
        },
        "commandSafety": {
          "enum": [
            "pr_safe",
            "trusted_only",
            "local_only"
          ]
        },
        "commandRunnable": {
          "type": "boolean"
        },
        "commandBlockedReason": {
          "type": "string"
        },
        "expectedArtifacts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "runbookCommand": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "lane",
        "command",
        "cwd",
        "safety",
        "description",
        "requiredSecrets",
        "expectedArtifacts"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "lane": {
          "enum": [
            "local",
            "pull_request",
            "ci",
            "schedule",
            "protected",
            "triage",
            "ui"
          ]
        },
        "command": {
          "type": "string"
        },
        "cwd": {
          "type": "string"
        },
        "safety": {
          "enum": [
            "pr_safe",
            "trusted_only",
            "local_only"
          ]
        },
        "description": {
          "type": "string"
        },
        "requiredSecrets": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "expectedArtifacts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "runProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "description",
        "commandIds",
        "safety",
        "enabled",
        "runnable",
        "blockedReasons",
        "expectedArtifacts",
        "requiredSecrets"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "commandIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "safety": {
          "enum": [
            "pr_safe",
            "trusted_only",
            "local_only"
          ]
        },
        "enabled": {
          "type": "boolean"
        },
        "runnable": {
          "type": "boolean"
        },
        "blockedReason": {
          "type": "string"
        },
        "blockedReasons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "expectedArtifacts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "requiredSecrets": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "failure": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "contractId",
        "targetId",
        "status",
        "classification",
        "errorExcerpt",
        "artifacts"
      ],
      "properties": {
        "contractId": {
          "type": "string"
        },
        "targetId": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "classification": {
          "type": "string"
        },
        "errorExcerpt": {
          "type": "string"
        },
        "artifacts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
