{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://visual-hive.dev/schemas/visual-hive.hive-agent-policy.schema.json",
  "title": "Visual Hive Hive Agent Policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "mode",
    "acmmLevel",
    "enabled",
    "externalCallsMade",
    "verdictAuthority",
    "hiveAuthority",
    "repair",
    "allowedActions",
    "forbiddenActions",
    "trustedWorkflowRequiredFor",
    "finalValidation"
  ],
  "properties": {
    "schemaVersion": {
      "const": "visual-hive.hive-agent-policy.v1"
    },
    "mode": {
      "enum": [
        "advisory",
        "measured",
        "repair_request",
        "guarded_repair",
        "full"
      ]
    },
    "acmmLevel": {
      "type": "integer",
      "minimum": 1,
      "maximum": 6
    },
    "enabled": {
      "type": "boolean"
    },
    "externalCallsMade": {
      "const": 0
    },
    "verdictAuthority": {
      "const": "visual_hive"
    },
    "hiveAuthority": {
      "const": "advisory_or_guarded_repair"
    },
    "repair": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "prOnly",
        "maxAttempts",
        "requireHumanReview",
        "rerunVisualHive",
        "branchPrefix"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "prOnly": {
          "type": "boolean"
        },
        "maxAttempts": {
          "type": "integer",
          "minimum": 1
        },
        "requireHumanReview": {
          "type": "boolean"
        },
        "rerunVisualHive": {
          "type": "boolean"
        },
        "branchPrefix": {
          "type": "string"
        }
      }
    },
    "allowedActions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "forbiddenActions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "trustedWorkflowRequiredFor": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "finalValidation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required",
        "command",
        "passFailOwnedBy"
      ],
      "properties": {
        "required": {
          "const": true
        },
        "command": {
          "type": "string"
        },
        "passFailOwnedBy": {
          "const": "visual_hive_verdict_engine"
        }
      }
    }
  }
}
