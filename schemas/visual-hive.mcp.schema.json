{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://visual-hive.dev/schemas/visual-hive.mcp.schema.json",
  "title": "Visual Hive MCP Manifest",
  "type": "object",
  "required": [
    "schemaVersion",
    "project",
    "server",
    "resources",
    "tools",
    "disabledExecutionTools",
    "policy"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "visual-hive.mcp.v1"
    },
    "project": {
      "type": "string",
      "minLength": 1
    },
    "server": {
      "type": "object",
      "required": [
        "name",
        "transport",
        "defaultAccess",
        "externalCallsMade"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "const": "visual-hive"
        },
        "transport": {
          "const": "stdio"
        },
        "defaultAccess": {
          "const": "read_only"
        },
        "externalCallsMade": {
          "const": 0
        }
      }
    },
    "resources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/resource"
      }
    },
    "tools": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/readOnlyTool"
      }
    },
    "disabledExecutionTools": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/disabledTool"
      }
    },
    "policy": {
      "type": "object",
      "required": [
        "thirdPartyMcpDefault",
        "executionToolsDefault",
        "githubWritesFromPr",
        "externalUploadsFromPr",
        "baselineApprovalByAgent",
        "llmSoleOracle"
      ],
      "additionalProperties": false,
      "properties": {
        "thirdPartyMcpDefault": {
          "const": "disabled"
        },
        "executionToolsDefault": {
          "const": "disabled"
        },
        "githubWritesFromPr": {
          "const": false
        },
        "externalUploadsFromPr": {
          "const": false
        },
        "baselineApprovalByAgent": {
          "const": false
        },
        "llmSoleOracle": {
          "const": false
        }
      }
    }
  },
