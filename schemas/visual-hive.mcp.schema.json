{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://visual-hive.dev/schemas/visual-hive.mcp.schema.json",
  "title": "Visual Hive MCP Manifest",
  "type": "object",
  "required": [
    "schemaVersion",
    "project",
    "server",
    "resources",
    "tools",
    "disabledExecutionTools",
    "policy"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": "visual-hive.mcp.v1" },
    "project": { "type": "string", "minLength": 1 },
    "server": {
      "type": "object",
      "required": ["name", "transport", "defaultAccess", "externalCallsMade"],
      "additionalProperties": false,
      "properties": {
        "name": { "const": "visual-hive" },
        "transport": { "const": "stdio" },
        "defaultAccess": { "const": "read_only" },
        "externalCallsMade": { "const": 0 }
      }
    },
    "resources": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/resource" }
    },
    "tools": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/readOnlyTool" }
    },
    "disabledExecutionTools": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/disabledTool" }
    },
    "policy": {
      "type": "object",
      "required": [
        "thirdPartyMcpDefault",
        "executionToolsDefault",
        "githubWritesFromPr",
        "externalUploadsFromPr",
        "baselineApprovalByAgent",
        "llmSoleOracle"
      ],
      "additionalProperties": false,
      "properties": {
        "thirdPartyMcpDefault": { "const": "disabled" },
        "executionToolsDefault": { "const": "disabled" },
        "githubWritesFromPr": { "const": false },
        "externalUploadsFromPr": { "const": false },
        "baselineApprovalByAgent": { "const": false },
        "llmSoleOracle": { "const": false }
      }
    }
  },
  "$defs": {
    "resource": {
      "type": "object",
      "required": ["uri", "name", "title", "description", "relativePath", "mimeType"],
      "additionalProperties": false,
      "properties": {
        "uri": {
          "type": "string",
          "enum": [
            "visual-hive://config",
            "visual-hive://latest-plan",
            "visual-hive://latest-report",
            "visual-hive://latest-evidence",
            "visual-hive://latest-verdict",
            "visual-hive://latest-handoff",
            "visual-hive://coverage-map",
            "visual-hive://mutation-report",
            "visual-hive://repair-prompt",
            "visual-hive://artifacts/index",
            "visual-hive://agent-packet",
            "visual-hive://tool-registry",
            "visual-hive://context-ledger",
            "visual-hive://pipeline-status"
          ]
        },
        "name": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "relativePath": { "type": "string", "minLength": 1 },
        "mimeType": {
          "type": "string",
          "enum": ["application/json", "text/markdown", "text/yaml"]
        }
      }
    },
    "readOnlyTool": {
      "type": "object",
      "required": ["name", "title", "description", "mode"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "enum": [
            "visual_hive_doctor",
            "visual_hive_validate_config",
            "visual_hive_recommend_setup",
            "visual_hive_plan",
            "visual_hive_read_latest_report",
            "visual_hive_read_evidence_packet",
            "visual_hive_read_verdict",
            "visual_hive_read_agent_packet",
            "visual_hive_read_tool_registry",
            "visual_hive_read_context_ledger",
            "visual_hive_read_pipeline_status",
            "visual_hive_explain_failure",
            "visual_hive_list_reproduction_commands",
            "visual_hive_generate_repair_prompt",
            "visual_hive_generate_handoff_dry_run"
          ]
        },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "mode": { "const": "read_only" }
      }
    },
    "disabledTool": {
      "type": "object",
      "required": ["name", "title", "description", "mode"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "enum": [
            "visual_hive_run",
            "visual_hive_mutate",
            "visual_hive_update_baseline",
            "visual_hive_handoff_github_issue",
            "visual_hive_handoff_hive_bead",
            "visual_hive_provider_upload"
          ]
        },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "mode": { "const": "execution_disabled" }
      }
    }
  }
}
