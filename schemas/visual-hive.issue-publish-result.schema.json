{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://visual-hive.dev/schemas/visual-hive.issue-publish-result.schema.json",
  "title": "Visual Hive Issue Publish Result",
  "type": "object",
  "required": ["schemaVersion", "generatedAt", "project", "mode", "status", "externalCallsMade", "networkCallsMade", "realGithubIssuesCreated", "realGithubIssuesUpdated", "blockedReasons", "decisions", "createdIssues", "updatedIssues"],
  "properties": {
    "schemaVersion": { "const": "visual-hive.issue-publish-result.v1" },
    "generatedAt": { "type": "string" },
    "project": { "type": "string" },
    "mode": { "enum": ["dry_run", "live"] },
    "status": { "enum": ["ready", "blocked", "managed_by_hive", "dry_run_written", "published", "failed"] },
    "externalCallsMade": { "type": "number" },
    "networkCallsMade": { "type": "number" },
    "lifecycle": {
      "type": "object",
      "required": ["owner", "standaloneIssueWrites", "reason"],
      "properties": {
        "owner": { "enum": ["visual-hive", "hive"] },
        "standaloneIssueWrites": { "enum": ["allowed", "suppressed"] },
        "reason": { "type": "string" }
      },
      "additionalProperties": false
    },
    "realGithubIssuesCreated": { "type": "number" },
    "realGithubIssuesUpdated": { "type": "number" },
    "blockedReasons": { "type": "array", "items": { "type": "string" } },
    "decisions": { "type": "array", "items": { "type": "object" } },
    "createdIssues": { "type": "array", "items": { "type": "object" } },
    "updatedIssues": { "type": "array", "items": { "type": "object" } }
  },
  "additionalProperties": false
}
