{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://visual-hive.dev/schemas/visual-hive.provider-decisions.schema.json",
  "title": "Visual Hive Provider Decisions",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "generatedAt",
    "outputResource",
    "decisions"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "outputResource": {
      "$ref": "#/$defs/outputResource"
    },
    "decisions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/decision"
      }
    }
  },
  "$defs": {
    "outputResource": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "artifactPath",
        "evidenceResourceId",
        "evidenceResourceUri",
        "evidenceResourceTitle",
        "evidenceResourceDescription",
        "evidenceReadToolName"
      ],
      "properties": {
        "artifactPath": {
          "const": ".visual-hive/provider-decisions.json"
        },
        "evidenceResourceId": {
          "const": "provider-decisions"
        },
        "evidenceResourceUri": {
          "const": "visual-hive://provider-decisions"
        },
        "evidenceResourceTitle": {
          "type": "string"
        },
        "evidenceResourceDescription": {
          "type": "string"
        },
        "evidenceReadToolName": {
          "const": "visual_hive_read_provider_decisions"
        }
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "providerId",
        "decision",
        "reason",
        "decidedAt",
        "source",
        "externalCallsMade"
      ],
      "properties": {
        "providerId": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_-]{2,64}$"
        },
        "label": {
          "type": "string"
        },
        "decision": {
          "enum": [
            "skip",
            "review_later",
            "approve_trusted_setup"
          ]
        },
        "reason": {
          "type": "string"
        },
        "decidedAt": {
          "type": "string",
          "format": "date-time"
        },
        "source": {
          "enum": [
            "cli",
            "control-plane"
          ]
        },
        "externalCallsMade": {
          "const": 0
        }
      }
    }
  }
}
