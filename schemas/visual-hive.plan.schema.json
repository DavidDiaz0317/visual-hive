{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://visual-hive.dev/schemas/visual-hive.plan.schema.json",
  "title": "Visual Hive Plan",
  "type": "object",
  "required": [
    "schemaVersion",
    "project",
    "mode",
    "generatedAt",
    "changedFiles",
    "effectiveChangedFiles",
    "ignoredChangedFiles",
    "targets",
    "items",
    "excluded",
    "mutation",
    "providerPolicy"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "project": {
      "type": "string"
    },
    "mode": {
      "enum": [
        "pr",
        "schedule",
        "manual",
        "canary",
        "mutation",
        "full"
      ]
    },
    "generatedAt": {
      "type": "string"
    },
    "changedFiles": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "effectiveChangedFiles": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "ignoredChangedFiles": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ignoredChangedFile"
      }
    },
    "targets": {
      "type": "array"
    },
    "items": {
      "type": "array"
    },
    "excluded": {
      "type": "array"
    },
    "providerPolicy": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/providerPolicy"
      }
    },
    "mutation": {
      "type": "object",
      "required": [
        "enabled",
        "operators",
        "minScore",
        "reasons"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "operators": {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "$ref": "#/$defs/mutationOperator"
              },
              {
                "type": "object",
                "required": [
                  "id"
                ],
                "additionalProperties": false,
                "properties": {
                  "id": {
                    "$ref": "#/$defs/mutationOperator"
                  },
                  "contracts": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            ]
          }
        },
        "minScore": {
          "type": "number"
        },
        "reasons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  },
  "$defs": {
    "ignoredChangedFile": {
      "type": "object",
      "required": [
        "file",
        "pattern",
        "reason"
      ],
      "additionalProperties": false,
      "properties": {
        "file": {
          "type": "string"
        },
        "pattern": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        }
      }
    },
    "mutationOperator": {
      "enum": [
        "hide-critical-button",
        "force-login-on-demo",
        "remove-demo-badge",
        "api-500",
        "empty-data",
        "mobile-overflow",
        "route-guard-bypass",
        "hidden-error-banner",
        "broken-image",
        "removed-accessible-name",
        "theme-token-drift",
        "stale-loading-state"
      ]
    },
    "providerPolicy": {
      "type": "object",
      "required": [
        "providerId",
        "label",
        "enabled",
        "mode",
        "availability",
        "deterministicRole",
        "requiredEnv",
        "missingEnv",
        "externalUploadAllowed",
        "externalUploadBlockedReasons",
        "estimatedExternalScreenshots",
        "externalCallsPlanned",
        "reasons"
      ],
      "additionalProperties": false,
      "properties": {
        "providerId": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "enabled": {
          "type": "boolean"
        },
        "mode": {
          "enum": [
            "mock",
            "external"
          ]
        },
        "availability": {
          "enum": [
            "available",
            "disabled",
            "missing_credentials",
            "mock",
            "policy_blocked"
          ]
        },
        "deterministicRole": {
          "enum": [
            "oracle",
            "supplemental"
          ]
        },
        "requiredEnv": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "missingEnv": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "externalUploadAllowed": {
          "type": "boolean"
        },
        "externalUploadBlockedReasons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "estimatedExternalScreenshots": {
          "type": "integer",
          "minimum": 0
        },
        "externalCallsPlanned": {
          "const": 0
        },
        "reasons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
