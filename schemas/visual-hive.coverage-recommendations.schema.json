{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://visual-hive.dev/schemas/visual-hive.coverage-recommendations.schema.json",
  "title": "Visual Hive Coverage Improvement Recommendations",
  "type": "object",
  "required": [
    "schemaVersion",
    "project",
    "generatedAt",
    "summary",
    "maintenanceFindings",
    "recommendations"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "project": {
      "type": "string"
    },
    "generatedAt": {
      "type": "string"
    },
    "outputResource": {
      "$ref": "#/$defs/outputResource"
    },
    "summary": {
      "type": "object",
      "required": [
        "total",
        "high",
        "medium",
        "low",
        "fromCoverageGaps",
        "fromMutationSurvivors",
        "fromFlowGaps",
        "fromMaintenanceFindings"
      ],
      "properties": {
        "total": {
          "type": "integer",
          "minimum": 0
        },
        "high": {
          "type": "integer",
          "minimum": 0
        },
        "medium": {
          "type": "integer",
          "minimum": 0
        },
        "low": {
          "type": "integer",
          "minimum": 0
        },
        "fromCoverageGaps": {
          "type": "integer",
          "minimum": 0
        },
        "fromMutationSurvivors": {
          "type": "integer",
          "minimum": 0
        },
        "fromFlowGaps": {
          "type": "integer",
          "minimum": 0
        },
        "fromMaintenanceFindings": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "maintenanceFindings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/maintenanceFinding"
      }
    },
    "recommendations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "kind",
          "severity",
          "title",
          "rationale",
          "suggestedTests"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "kind": {
            "enum": [
              "add_contract",
              "add_screenshot",
              "add_selector_assertion",
              "add_flow_steps",
              "add_changed_file_rule",
              "map_mutation_operator",
              "maintain_visual_test"
            ]
          },
          "severity": {
            "enum": [
              "low",
              "medium",
              "high"
            ]
          },
          "title": {
            "type": "string"
          },
          "rationale": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "targetId": {
            "type": "string"
          },
          "contractId": {
            "type": "string"
          },
          "route": {
            "type": "string"
          },
          "viewport": {
            "type": "string"
          },
          "changedFile": {
            "type": "string"
          },
          "mutationOperator": {
            "type": "string"
          },
          "maintenanceFindingId": {
            "type": "string"
          },
          "lane": {
            "enum": [
              "pull_request",
              "scheduled",
              "protected",
              "manual"
            ]
          },
          "trustedOnly": {
            "type": "boolean"
          },
          "suggestedConfigYaml": {
            "type": "string"
          },
          "suggestedTests": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "maintenanceFinding": {
      "type": "object",
      "required": [
        "id",
        "kind",
        "severity",
        "contractId",
        "targetId",
        "message",
        "evidence",
        "recommendedAction",
        "hiveOwner",
        "validationCommand"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "kind": {
          "enum": [
            "stale_baseline",
            "baseline_churn",
            "mutation_survivor",
            "screenshot_without_assertion",
            "generic_selector",
            "duplicate_screenshot",
            "overbroad_full_page",
            "missing_mobile_viewport",
            "weak_threshold"
          ]
        },
        "severity": {
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "contractId": {
          "type": "string"
        },
        "targetId": {
          "type": "string"
        },
        "route": {
          "type": "string"
        },
        "viewport": {
          "type": "string"
        },
        "screenshotName": {
          "type": "string"
        },
        "mutationOperator": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "recommendedAction": {
          "enum": [
            "remove",
            "fix",
            "expand",
            "shrink",
            "split",
            "add_assertion"
          ]
        },
        "hiveOwner": {
          "enum": [
            "quality",
            "ci-maintainer"
          ]
        },
        "validationCommand": {
          "type": "string"
        }
      }
    },
    "outputResource": {
      "type": "object",
      "required": [
        "artifactPath",
        "evidenceResourceId",
        "evidenceResourceUri",
        "evidenceResourceTitle",
        "evidenceResourceDescription"
      ],
      "additionalProperties": false,
      "properties": {
        "artifactPath": {
          "const": ".visual-hive/coverage-recommendations.json"
        },
        "evidenceResourceId": {
          "const": "coverage-recommendations"
        },
        "evidenceResourceUri": {
          "const": "visual-hive://coverage-recommendations"
        },
        "evidenceResourceTitle": {
          "const": "Coverage Recommendations"
        },
        "evidenceResourceDescription": {
          "type": "string"
        },
        "evidenceReadToolName": {
          "const": "visual_hive_read_coverage_recommendations"
        }
      }
    }
  }
}
