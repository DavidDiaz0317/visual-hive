    "authorization": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "authorizationId",
        "issuedAt",
        "expiresAt",
        "repositoryFingerprint",
        "taskContextDigest",
        "baseSha",
        "profile",
        "toolNames",
        "assetIds",
        "budgetDigest",
        "configDigest",
        "toolRegistryDigest",
        "promptSchemaDigest",
        "authorizationDigest"
      ],
      "properties": {
        "authorizationId": {
          "$ref": "#/$defs/boundedId"
        },
        "issuedAt": {
          "$ref": "#/$defs/timestamp"
        },
        "expiresAt": {
          "$ref": "#/$defs/timestamp"
        },
        "repositoryFingerprint": {
          "$ref": "#/$defs/sha256"
        },
        "taskContextDigest": {
          "$ref": "#/$defs/sha256"
        },
        "baseSha": {
          "$ref": "#/$defs/gitCommit"
        },
        "profile": {
          "$ref": "#/$defs/profile"
        },
        "toolNames": {
          "type": "array",
          "items": {
            "enum": [
              "visual_hive_get_task_context",
              "visual_hive_get_issue_context",
              "visual_hive_search_surface",
              "visual_hive_get_visual_asset",
              "visual_hive_get_screenshot_set",
              "visual_hive_get_browser_evidence",
              "visual_hive_compare_assets",
              "visual_hive_get_repair_validation"
            ]
          },
          "minItems": 8,
          "maxItems": 8,
          "uniqueItems": true
        },
        "assetIds": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/boundedId"
          },
          "maxItems": 128,
          "uniqueItems": true
        },
        "budgetDigest": {
          "$ref": "#/$defs/sha256"
        },
        "configDigest": {
          "$ref": "#/$defs/sha256"
        },
        "toolRegistryDigest": {
          "$ref": "#/$defs/sha256"
        },
        "promptSchemaDigest": {
          "$ref": "#/$defs/sha256"
        },
        "authorizationDigest": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "attempt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "attemptId",
        "ordinal",
        "state",
        "startedAt",
        "promptDigest",
        "turnIds",
        "validationRequestIds"
      ],
      "properties": {
        "attemptId": {
          "$ref": "#/$defs/boundedId"
        },
        "ordinal": {
          "type": "integer",
          "minimum": 0
        },
        "state": {
          "enum": [
            "started",
            "candidate",
            "failed",
            "blocked",
            "exhausted"
          ]
        },
        "startedAt": {
          "$ref": "#/$defs/timestamp"
        },
        "completedAt": {
          "$ref": "#/$defs/timestamp"
        },
        "promptDigest": {
          "$ref": "#/$defs/sha256"
        },
        "turnIds": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/sha256"
          },
          "maxItems": 128,
          "uniqueItems": true
        },
        "candidatePatchDigest": {
          "$ref": "#/$defs/sha256"
        },
        "candidateHeadSha": {
          "$ref": "#/$defs/gitCommit"
        },
        "candidateHeadTreeSha": {
          "$ref": "#/$defs/gitCommit"
        },
        "validationRequestIds": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/boundedId"
          },
          "maxItems": 128,
          "uniqueItems": true
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "state": {
                "const": "started"
              }
            },
            "required": [
              "state"
            ]
          },
          "then": {
            "not": {
              "required": [
                "completedAt"
              ]
            }
          }
        },
        {
          "if": {
            "properties": {
              "state": {
                "const": "candidate"
              }
            },
            "required": [
              "state"
            ]
          },
          "then": {
            "required": [
              "completedAt",
              "candidatePatchDigest",
              "candidateHeadSha",
              "candidateHeadTreeSha"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "state": {
                "enum": [
                  "failed",
                  "blocked",
                  "exhausted"
                ]
              }
            },
            "required": [
              "state"
            ]
          },
          "then": {
            "required": [
              "completedAt"
            ]
          }
        },
        {
          "if": {
            "anyOf": [
              {
                "required": [
                  "candidatePatchDigest"
                ]
              },
              {
                "required": [
                  "candidateHeadSha"
                ]
              },
              {
                "required": [
                  "candidateHeadTreeSha"
                ]
              }
            ]
          },
          "then": {
            "required": [
              "candidatePatchDigest",
              "candidateHeadSha",
              "candidateHeadTreeSha"
            ]
          }
        }
      ]
    },
    "turn": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "turnId",
        "attemptId",
        "ordinal",
        "state",
        "startedAt",
        "inputDigest",
        "providerInputDigest",
        "consumedToolOutcomeDigests",
        "providerIdentityDigest"
      ],
      "properties": {
        "turnId": {
          "$ref": "#/$defs/sha256"
        },
        "attemptId": {
          "$ref": "#/$defs/boundedId"
        },
        "ordinal": {
          "type": "integer",
          "minimum": 0
        },
        "state": {
          "enum": [
            "started",
            "completed",
            "failed",
            "blocked",
            "lost"
          ]
        },
        "startedAt": {
          "$ref": "#/$defs/timestamp"
        },
        "completedAt": {
          "$ref": "#/$defs/timestamp"
        },
        "inputDigest": {
          "$ref": "#/$defs/sha256"
        },
        "providerInputDigest": {
          "$ref": "#/$defs/sha256"
        },
        "previousTurnOutputDigest": {
          "$ref": "#/$defs/sha256"
        },
        "consumedToolOutcomeDigests": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/sha256"
          },
          "maxItems": 128,
          "uniqueItems": true
        },
        "providerIdentityDigest": {
          "$ref": "#/$defs/sha256"
        },
        "usage": {
          "$ref": "#/$defs/providerUsage"
        },
        "providerReceiptDigest": {
          "$ref": "#/$defs/sha256"
        },
        "outputKind": {
          "enum": [
            "tool_request",
            "final_result",
            "error"
          ]
        },
        "outputDigest": {
          "$ref": "#/$defs/sha256"
        },
        "toolCallId": {
          "$ref": "#/$defs/sha256"
        },
        "errorCode": {
          "$ref": "#/$defs/boundedId"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "state": {
                "const": "started"
              }
            },
            "required": [
              "state"
            ]
          },
          "then": {
            "not": {
              "anyOf": [
                {
                  "required": [
                    "completedAt"
                  ]
                },
                {
                  "required": [
                    "outputKind"
                  ]
                },
                {
                  "required": [
                    "outputDigest"
                  ]
                },
                {
                  "required": [
                    "toolCallId"
                  ]
                },
                {
                  "required": [
                    "errorCode"
                  ]
                },
                {
                  "required": [
                    "usage"
                  ]
                },
                {
                  "required": [
                    "providerReceiptDigest"
                  ]
                }
              ]
            }
          }
        },
        {
          "if": {
            "properties": {
              "state": {
                "const": "completed"
              }
            },
            "required": [
              "state"
            ]
          },
          "then": {
            "required": [
              "completedAt",
              "outputKind",
              "outputDigest",
              "usage",
              "providerReceiptDigest"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "state": {
                "enum": [
                  "failed",
                  "blocked"
                ]
              }
            },
            "required": [
              "state"
            ]
          },
          "then": {
            "required": [
              "completedAt",
              "errorCode",
              "usage",
              "providerReceiptDigest"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "state": {
                "const": "lost"
              }
            },
            "required": [
              "state"
            ]
          },
          "then": {
            "required": [
              "completedAt",
              "errorCode",
              "usage"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "outputKind": {
                "const": "tool_request"
              }
            },
            "required": [
              "outputKind"
            ]
          },
          "then": {
            "required": [
              "toolCallId"
            ]
          },
          "else": {
            "not": {
              "required": [
                "toolCallId"
              ]
            }
          }
        }
      ]
    },
    "validationRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requestId",
        "idempotencyKey",
        "sessionId",
        "attemptId",
        "kind",
        "commitRole",
        "profileId",
        "profileDigest",
        "commitSha",
        "requestDigest",
        "state",
        "requestedAt"
      ],
      "properties": {
        "requestId": {
          "$ref": "#/$defs/boundedId"
        },
        "idempotencyKey": {
          "$ref": "#/$defs/sha256"
        },
        "sessionId": {
          "$ref": "#/$defs/sha256"
        },
        "attemptId": {
          "$ref": "#/$defs/boundedId"
        },
        "kind": {
          "enum": [
            "reproduction",
            "capture",
            "patch_validation"
          ]
        },
        "commitRole": {
          "enum": [
            "base",
            "candidate"
          ]
        },
        "profileId": {
          "$ref": "#/$defs/boundedId"
        },
        "profileDigest": {
          "$ref": "#/$defs/sha256"
        },
        "commitSha": {
          "$ref": "#/$defs/gitCommit"
        },
        "authorizationDigest": {
          "$ref": "#/$defs/sha256"
        },
        "requestDigest": {
          "$ref": "#/$defs/sha256"
        },
        "state": {
          "enum": [
            "requested",
            "started",
            "completed",
            "failed",
            "blocked",
            "lost"
          ]
        },
        "requestedAt": {
          "$ref": "#/$defs/timestamp"
        },
        "startedAt": {
          "$ref": "#/$defs/timestamp"
        },
        "completedAt": {
          "$ref": "#/$defs/timestamp"
        },
        "receiptDigest": {
          "$ref": "#/$defs/sha256"
        },
        "errorCode": {
          "$ref": "#/$defs/boundedId"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "state": {
                "const": "requested"
              }
            },
            "required": [
              "state"
            ]
          },
          "then": {
            "not": {
              "anyOf": [
                {
                  "required": [
                    "startedAt"
                  ]
                },
                {
                  "required": [
                    "completedAt"
                  ]
                },
                {
                  "required": [
                    "receiptDigest"
                  ]
                },
                {
                  "required": [
                    "errorCode"
                  ]
                }
              ]
            }
          }
        },
        {
          "if": {
            "properties": {
              "state": {
                "const": "started"
              }
            },
            "required": [
              "state"
            ]
          },
          "then": {
            "required": [
              "startedAt"
            ],
            "not": {
              "anyOf": [
                {
                  "required": [
                    "completedAt"
                  ]
                },
                {
                  "required": [
                    "receiptDigest"
                  ]
                },
                {
                  "required": [
                    "errorCode"
                  ]
                }
              ]
            }
          }
        },
        {
          "if": {
            "properties": {
              "state": {
                "const": "completed"
              }
            },
            "required": [
              "state"
            ]
          },
          "then": {
            "required": [
              "startedAt",
              "completedAt",
              "receiptDigest"
            ],
            "not": {
              "required": [
                "errorCode"
              ]
            }
          }
        },
        {
          "if": {
            "properties": {
              "state": {
                "enum": [
                  "failed",
                  "blocked",
                  "lost"
                ]
              }
            },
            "required": [
              "state"
            ]
          },
          "then": {
            "required": [
              "completedAt",
              "errorCode"
            ]
          }
        }
      ]
    }
  }
