{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://visual-hive.dev/schemas/visual-hive.adapter-lifecycle-plan.schema.json",
  "title": "Visual Hive Adapter Lifecycle Plan",
  "type": "object",
  "required": [
    "schemaVersion",
    "generatedAt",
    "project",
    "status",
    "mode",
    "repositoryRoot",
    "packageRoot",
    "packageManager",
    "defaultEvidenceAdapter",
    "verdictAuthority",
    "externalCallsMade",
    "dependencyWritesMade",
    "summary",
    "adapters",
    "notes"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": "visual-hive.adapter-lifecycle-plan.v1" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "project": { "type": "string", "minLength": 1 },
    "status": { "enum": ["ready", "action_required", "blocked"] },
    "mode": { "enum": ["plan", "apply"] },
    "repositoryRoot": { "const": "." },
    "packageRoot": { "type": "string", "minLength": 1 },
    "packageManager": { "enum": ["npm", "unsupported", "unavailable"] },
    "defaultEvidenceAdapter": { "const": "playwright" },
    "verdictAuthority": { "const": "visual-hive" },
    "externalCallsMade": { "const": 0 },
    "dependencyWritesMade": { "type": "boolean" },
    "summary": {
      "type": "object",
      "required": ["screenshotContracts", "ready", "actionRequired", "blocked", "notApplicable"],
      "additionalProperties": false,
      "properties": {
        "screenshotContracts": { "type": "integer", "minimum": 0 },
        "ready": { "type": "integer", "minimum": 0 },
        "actionRequired": { "type": "integer", "minimum": 0 },
        "blocked": { "type": "integer", "minimum": 0 },
        "notApplicable": { "type": "integer", "minimum": 0 }
      }
    },
    "adapters": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": { "$ref": "#/$defs/adapter" }
    },
    "notes": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "adapter": {
      "type": "object",
      "required": [
        "id",
        "label",
        "selected",
        "decision",
        "status",
        "evidenceRole",
        "verdictAuthority",
        "targetVersion",
        "reason",
        "lifecycle",
        "signals",
        "actions"
      ],
      "additionalProperties": false,
      "properties": {
        "id": { "enum": ["odiff_local_compare", "visual_regression_tracker_review"] },
        "label": { "type": "string", "minLength": 1 },
        "selected": { "type": "boolean" },
        "decision": { "enum": ["install", "update", "use", "skip", "replace"] },
        "status": { "enum": ["ready", "action_required", "blocked", "not_applicable"] },
        "evidenceRole": { "const": "supplemental" },
        "verdictAuthority": { "const": false },
        "targetVersion": { "type": "string", "minLength": 1 },
        "installedVersion": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 },
        "lifecycle": { "$ref": "#/$defs/adapterLifecycle" },
        "signals": {
          "type": "object",
          "required": [
            "screenshotContracts",
            "platform",
            "packageJson",
            "packageLock",
            "credentialNamesPresent",
            "credentialNamesMissing",
            "pullRequestLane"
          ],
          "additionalProperties": false,
          "properties": {
            "screenshotContracts": { "type": "integer", "minimum": 0 },
            "platform": { "type": "string", "minLength": 1 },
            "packageJson": { "type": "boolean" },
            "packageLock": { "type": "boolean" },
            "packagePin": { "type": "string", "minLength": 1 },
            "lockIntegrityVerified": { "type": "boolean" },
            "credentialNamesPresent": {
              "type": "array",
              "items": { "enum": ["VRT_APIURL", "VRT_APIKEY", "VRT_PROJECT", "VRT_BRANCH"] },
              "uniqueItems": true
            },
            "credentialNamesMissing": {
              "type": "array",
              "items": { "enum": ["VRT_APIURL", "VRT_APIKEY", "VRT_PROJECT", "VRT_BRANCH"] },
              "uniqueItems": true
            },
            "pullRequestLane": { "type": "boolean" }
          }
        },
        "actions": {
          "type": "array",
          "items": { "$ref": "#/$defs/action" }
        }
      }
    },
    "adapterLifecycle": {
      "type": "object",
      "required": [
        "version",
        "license",
        "capabilities",
        "installation",
        "healthCheck",
        "outputSchema",
        "platforms",
        "maturity",
        "maintenanceStatus",
        "lastReviewed",
        "source",
        "updatePolicy",
        "replacementCriteria",
        "rollback"
      ],
      "additionalProperties": false,
      "properties": {
        "version": { "type": "string", "minLength": 1 },
        "license": { "type": "string", "minLength": 1 },
        "capabilities": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "installation": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "healthCheck": { "type": "string", "minLength": 1 },
        "outputSchema": { "type": "string", "pattern": "^schemas/visual-hive\\..+\\.schema\\.json$" },
        "platforms": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "maturity": { "enum": ["experimental", "candidate", "stable", "deprecated"] },
        "maintenanceStatus": { "enum": ["maintained", "watch", "unmaintained"] },
        "lastReviewed": { "type": "string", "format": "date" },
        "source": { "type": "string", "format": "uri" },
        "updatePolicy": { "type": "string", "minLength": 1 },
        "replacementCriteria": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "rollback": { "type": "string", "minLength": 1 }
      }
    },
    "action": {
      "type": "object",
      "required": ["id", "kind", "status", "automatic", "reason"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": { "enum": ["install", "update", "health_check", "parity_check", "use", "replace", "review"] },
        "status": { "enum": ["planned", "passed", "failed", "skipped"] },
        "automatic": { "type": "boolean" },
        "command": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 }
      }
    }
  }
}
