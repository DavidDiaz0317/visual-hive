{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://visual-hive.dev/schemas/visual-hive.baseline-approvals.schema.json",
  "title": "Visual Hive Baseline Approval Log",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "approvals"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "approvals": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "schemaVersion",
          "approvedAt",
          "contractId",
          "screenshotName",
          "route",
          "viewport",
          "sourceStatus",
          "actualPath",
          "baselinePath",
          "bytes"
        ],
        "properties": {
          "schemaVersion": { "const": 1 },
          "approvedAt": { "type": "string" },
          "contractId": { "type": "string", "minLength": 1 },
          "screenshotName": { "type": "string", "minLength": 1 },
          "route": { "type": "string" },
          "viewport": { "type": "string", "minLength": 1 },
          "sourceStatus": { "enum": ["passed", "failed", "created", "missing_baseline"] },
          "actualPath": { "type": "string", "minLength": 1 },
          "baselinePath": { "type": "string", "minLength": 1 },
          "diffPath": { "type": "string" },
          "bytes": { "type": "number", "minimum": 0 }
        }
      }
    }
  }
}
