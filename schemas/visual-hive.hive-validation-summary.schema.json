{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://visual-hive.dev/schemas/visual-hive.hive-validation-summary.schema.json",
  "title": "Visual Hive Hive Validation Summary",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "generatedAt",
    "project",
    "status",
    "externalCallsMade",
    "hiveExportPath",
    "importManifestPath",
    "checks",
    "summary",
    "safety"
  ],
  "properties": {
    "schemaVersion": { "const": "visual-hive.hive-validation-summary.v1" },
    "generatedAt": { "type": "string" },
    "project": { "type": "string" },
    "status": { "enum": ["passed", "failed"] },
    "externalCallsMade": { "const": 0 },
    "hiveExportPath": { "type": "string" },
    "importManifestPath": { "type": "string" },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "status", "message"],
        "properties": {
          "id": { "type": "string" },
          "status": { "enum": ["passed", "failed"] },
          "message": { "type": "string" }
        }
      }
    },
    "summary": { "$ref": "#/$defs/summary" },
    "safety": { "$ref": "#/$defs/safety" }
  },
  "$defs": {
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["beads", "knowledgeFacts", "graphNodes", "graphEdges", "agentWorkOrders", "blockedReasons"],
      "properties": {
        "beads": { "type": "integer", "minimum": 0 },
        "knowledgeFacts": { "type": "integer", "minimum": 0 },
        "graphNodes": { "type": "integer", "minimum": 0 },
        "graphEdges": { "type": "integer", "minimum": 0 },
        "agentWorkOrders": { "type": "integer", "minimum": 0 },
        "blockedReasons": { "type": "integer", "minimum": 0 }
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pathSanitizationStatus",
        "absolutePathLeaks",
        "secretLeaks",
        "externalCallsMade",
        "networkCallsMade",
        "visualHiveCreatesBeads",
        "visualHiveCreatesIssues",
        "visualHiveRepairsCode"
      ],
      "properties": {
        "pathSanitizationStatus": { "enum": ["passed", "failed"] },
        "absolutePathLeaks": { "type": "integer", "minimum": 0 },
        "secretLeaks": { "type": "integer", "minimum": 0 },
        "externalCallsMade": { "const": 0 },
        "networkCallsMade": { "const": 0 },
        "visualHiveCreatesBeads": { "const": false },
        "visualHiveCreatesIssues": { "const": false },
        "visualHiveRepairsCode": { "const": false }
      }
    }
  }
}
