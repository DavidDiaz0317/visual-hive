{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://visual-hive.dev/schemas/visual-hive.hive-wiki-index.schema.json",
  "title": "Visual Hive Hive Wiki Index",
  "type": "object",
  "required": [
    "schemaVersion",
    "generatedAt",
    "project",
    "externalCallsMade",
    "wikiVaultDir",
    "pages"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "visual-hive.hive-wiki-index.v1"
    },
    "generatedAt": {
      "type": "string"
    },
    "project": {
      "type": "string"
    },
    "externalCallsMade": {
      "const": 0
    },
    "wikiVaultDir": {
      "type": "string"
    },
    "pages": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/page"
      }
    }
  },
  "$defs": {
    "page": {
      "type": "object",
      "required": [
        "slug",
        "title",
        "type",
        "source",
        "path",
        "tags",
        "relatedEvidenceKeys",
        "artifacts"
      ],
      "additionalProperties": false,
      "properties": {
        "slug": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "type": {
          "enum": [
            "pattern",
            "gotcha",
            "decision",
            "regression",
            "test_scaffold",
            "integration",
            "coverage_rule"
          ]
        },
        "source": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "relatedEvidenceKeys": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "artifacts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
