{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://visual-hive.dev/schemas/visual-hive.recommendations.schema.json",
  "title": "Visual Hive Setup Recommendation Report",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schemaVersion",
    "project",
    "generatedAt",
    "configPath",
    "setupProfile",
    "providerRecommendations",
    "costEstimate",
    "permissions",
    "setupPullRequest",
    "recommendedConfig",
    "recommendedConfigYaml",
    "detectedSelectors",
    "recommendedTarget",
    "recommendedContracts",
    "recommendedCommands",
    "findings",
    "warnings"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "project": {
      "type": "object",
      "required": ["name", "repoRoot", "type", "packageManager", "detectedFrameworks", "scripts"],
      "properties": {
        "name": { "type": "string" },
        "repoRoot": { "type": "string" },
        "type": { "enum": ["react-vite", "nextjs", "static", "dashboard", "custom"] },
        "packageManager": { "enum": ["npm", "pnpm", "yarn", "unknown"] },
        "detectedFrameworks": { "type": "array", "items": { "type": "string" } },
        "scripts": { "type": "array", "items": { "type": "string" } }
      }
    },
    "generatedAt": { "type": "string" },
    "configPath": { "type": "string" },
    "setupProfile": {
      "enum": ["free-local", "hosted-review", "component-storybook", "enterprise-visual-ai", "complex-app"]
    },
    "providerRecommendations": {
      "type": "array",
      "items": { "$ref": "#/$defs/providerRecommendation" }
    },
    "costEstimate": { "$ref": "#/$defs/costEstimate" },
    "permissions": { "$ref": "#/$defs/permissions" },
    "setupPullRequest": { "$ref": "#/$defs/setupPullRequest" },
    "recommendedConfig": { "type": "object" },
    "recommendedConfigYaml": { "type": "string" },
    "detectedSelectors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["selector", "sourceFile", "occurrences"],
        "properties": {
          "selector": { "type": "string" },
          "sourceFile": { "type": "string" },
          "occurrences": { "type": "number" }
        }
      }
    },
    "recommendedTarget": {
      "type": "object",
      "required": ["id", "kind", "url", "confidence", "reasons"],
      "properties": {
        "id": { "type": "string" },
        "kind": { "enum": ["url", "command", "commandGroup", "deployPreview", "storybook", "protected"] },
        "url": { "type": "string" },
        "install": { "type": "string" },
        "build": { "type": "string" },
        "serve": { "type": "string" },
        "confidence": { "enum": ["high", "medium", "low"] },
        "reasons": { "type": "array", "items": { "type": "string" } }
      }
    },
    "recommendedContracts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "targetId", "selectors", "steps", "screenshots", "reasons"],
        "properties": {
          "id": { "type": "string" },
          "targetId": { "type": "string" },
          "selectors": { "type": "array", "items": { "type": "string" } },
          "steps": { "type": "array", "items": { "type": "object" } },
          "screenshots": { "type": "array" },
          "reasons": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "recommendedCommands": { "type": "array", "items": { "type": "string" } },
    "findings": { "type": "array" },
    "warnings": { "type": "array", "items": { "type": "string" } }
  },
  "$defs": {
    "providerRecommendation": {
      "type": "object",
      "required": ["providerId", "label", "recommendation", "reason", "requiredEnv", "externalUploadAllowedByDefault"],
      "properties": {
        "providerId": { "type": "string" },
        "label": { "type": "string" },
        "recommendation": { "enum": ["use", "optional", "skip", "future"] },
        "reason": { "type": "string" },
        "requiredEnv": { "type": "array", "items": { "type": "string" } },
        "externalUploadAllowedByDefault": { "type": "boolean" }
      }
    },
    "costEstimate": {
      "type": "object",
      "required": [
        "localScreenshotsPerRun",
        "externalScreenshotsPerRun",
        "estimatedPrMinutes",
        "estimatedScheduledMinutes",
        "estimatedMonthlyExternalScreenshots",
        "ciRuntimeClass",
        "notes"
      ],
      "properties": {
        "localScreenshotsPerRun": { "type": "integer", "minimum": 0 },
        "externalScreenshotsPerRun": { "type": "integer", "minimum": 0 },
        "estimatedPrMinutes": { "type": "integer", "minimum": 0 },
        "estimatedScheduledMinutes": { "type": "integer", "minimum": 0 },
        "estimatedMonthlyExternalScreenshots": { "type": "integer", "minimum": 0 },
        "ciRuntimeClass": { "enum": ["cheap", "medium", "expensive"] },
        "notes": { "type": "array", "items": { "type": "string" } }
      }
    },
    "permissions": {
      "type": "object",
      "required": ["pullRequest", "scheduled"],
      "properties": {
        "pullRequest": { "$ref": "#/$defs/permissionLane" },
        "scheduled": { "$ref": "#/$defs/permissionLane" }
      }
    },
    "permissionLane": {
      "type": "object",
      "required": ["permissions", "secretsRequired", "externalNetwork", "notes"],
      "properties": {
        "permissions": { "type": "array", "items": { "type": "string" } },
        "secretsRequired": { "type": "array", "items": { "type": "string" } },
        "externalNetwork": { "type": "boolean" },
        "notes": { "type": "array", "items": { "type": "string" } }
      }
    },
    "setupPullRequest": {
      "type": "object",
      "required": ["recommended", "title", "files", "steps", "securityNotes"],
      "properties": {
        "recommended": { "type": "boolean" },
        "title": { "type": "string" },
        "files": { "type": "array", "items": { "type": "string" } },
        "steps": { "type": "array", "items": { "type": "string" } },
        "securityNotes": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
