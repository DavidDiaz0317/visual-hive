{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://visual-hive.dev/schemas/visual-hive.handoff-validation.schema.json",
  "title": "Visual Hive Hive Handoff Validation",
  "type": "object",
  "required": [
    "schemaVersion",
    "generatedAt",
    "project",
    "status",
    "sourceArtifacts",
    "summary",
    "checks",
    "blockedReasons",
    "warnings"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": "visual-hive.handoff-validation.v1" },
    "generatedAt": { "type": "string" },
    "project": { "type": "string" },
    "status": { "enum": ["passed", "warning", "blocked"] },
    "sourceArtifacts": {
      "type": "object",
      "required": ["evidencePacket", "handoff", "issue", "beadRequest", "result"],
      "additionalProperties": false,
      "properties": {
        "evidencePacket": { "type": "string" },
        "handoff": { "type": "string" },
        "issue": { "type": "string" },
        "beadRequest": { "type": "string" },
        "result": { "type": "string" }
      }
    },
    "summary": {
      "type": "object",
      "required": ["checksPassed", "warnings", "blocked", "externalCallsMade", "workItems"],
      "additionalProperties": false,
      "properties": {
        "checksPassed": { "type": "integer", "minimum": 0 },
        "warnings": { "type": "integer", "minimum": 0 },
        "blocked": { "type": "integer", "minimum": 0 },
        "externalCallsMade": { "type": "integer", "minimum": 0 },
        "workItems": { "type": "integer", "minimum": 0 }
      }
    },
    "checks": {
      "type": "array",
      "items": { "$ref": "#/$defs/check" }
    },
    "blockedReasons": { "type": "array", "items": { "type": "string" } },
    "warnings": { "type": "array", "items": { "type": "string" } }
  },
  "$defs": {
    "check": {
      "type": "object",
      "required": ["id", "label", "status", "evidence", "message"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "status": { "enum": ["passed", "warning", "blocked"] },
        "evidence": { "type": "array", "items": { "type": "string" } },
        "message": { "type": "string" }
      }
    }
  }
}
